<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-edit"></i> تعديل المادة
        </h3>
        <div class="card-tools">
            <a href="/branch" class="btn btn-default btn-sm">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
        </div>
    </div>
    
    {{#if error}}
    <div class="alert alert-danger m-3">
        <i class="fas fa-exclamation-circle"></i> {{error}}
    </div>
    {{/if}}
    
    <form action="/branch/edit/{{branch._id}}?_method=PUT" method="post">
        <div class="card-body">
            <div class="form-group">
                <label for="name">اسم المادة <span class="text-danger">*</span></label>
                <input type="text" 
                       class="form-control" 
                       id="name" 
                       name="name" 
                       value="{{branch.name}}" 
                       required>
                <small class="form-text text-muted">يمكنك تعديل اسم المادة إذا لزم الأمر</small>
            </div>
            
            <div class="alert alert-warning mt-3">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>تنبيه:</strong>
                قد يؤثر تعديل اسم المادة على الدروس المرتبطة بها.
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> تحديث
            </button>
            <a href="/branch" class="btn btn-default">
                <i class="fas fa-times"></i> إلغاء
            </a>
        </div>
    </form>
</div>