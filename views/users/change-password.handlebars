<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-key"></i> تغيير كلمة المرور
        </h3>
        <div class="card-tools">
            <a href="/users" class="btn-back">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
        </div>
    </div>
    
    <div class="card-body">
        <div class="password-info">
            <i class="fas fa-lock"></i>
            <div>
                <strong>{{user.fullName}}</strong>
                <span>تغيير كلمة المرور</span>
            </div>
        </div>
        
        {{#if error}}
        <div class="alert-error">{{error}}</div>
        {{/if}}
        
        <form action="/users/change-password/{{user._id}}" method="post" class="password-form">
            <div class="form-field">
                <label class="field-label">كلمة المرور الجديدة <span class="required">*</span></label>
                <input type="password" class="field-input" id="newPassword" name="newPassword" required>
                <small>6 أحرف على الأقل</small>
            </div>
            
            <div class="form-field">
                <label class="field-label">تأكيد كلمة المرور <span class="required">*</span></label>
                <input type="password" class="field-input" id="confirmPassword" required>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i> تغيير كلمة المرور
                </button>
                <a href="/users" class="btn-cancel">إلغاء</a>
            </div>
        </form>
    </div>
</div>

<style>
.password-info {
    background: #f1f5f9;
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.password-info i {
    font-size: 2rem;
    color: #3b82f6;
}

.password-info strong {
    display: block;
    font-size: 1rem;
    color: #1e293b;
}

.password-info span {
    font-size: 0.75rem;
    color: #64748b;
}

.password-form {
    max-width: 400px;
}
</style>

<script>
document.querySelector('form')?.addEventListener('submit', function(e) {
    const newPass = document.getElementById('newPassword').value;
    const confirmPass = document.getElementById('confirmPassword').value;
    
    if (newPass !== confirmPass) {
        e.preventDefault();
        alert('كلمة المرور غير متطابقة');
        return false;
    }
    
    if (newPass.length < 6) {
        e.preventDefault();
        alert('كلمة المرور يجب أن تكون 6 أحرف على الأقل');
        return false;
    }
});
</script>