<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-cloud-upload-alt"></i> رفع المحتوى
        </h3>
        <div class="card-tools">
            <a href="/lesson" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
        </div>
    </div>
    
    <div class="card-body">
        <!-- إحصائيات سريعة -->
        <div class="row g-4 mb-4">
            <div class="col-md-2 col-6">
                <div class="stat-card-sm">
                    <div class="stat-icon-sm bg-primary">
                        <i class="fas fa-video"></i>
                    </div>
                    <div class="stat-info-sm">
                        <div class="stat-number-sm">{{stats.videos}}</div>
                        <div class="stat-label-sm">فيديوهات</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="stat-card-sm">
                    <div class="stat-icon-sm bg-danger">
                        <i class="fas fa-file-pdf"></i>
                    </div>
                    <div class="stat-info-sm">
                        <div class="stat-number-sm">{{stats.pdfs}}</div>
                        <div class="stat-label-sm">PDF</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="stat-card-sm">
                    <div class="stat-icon-sm bg-success">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div class="stat-info-sm">
                        <div class="stat-number-sm">{{stats.texts}}</div>
                        <div class="stat-label-sm">نصوص</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="stat-card-sm">
                    <div class="stat-icon-sm bg-warning">
                        <i class="fas fa-question-circle"></i>
                    </div>
                    <div class="stat-info-sm">
                        <div class="stat-number-sm">{{stats.quizzes}}</div>
                        <div class="stat-label-sm">اختبارات</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="stat-card-sm">
                    <div class="stat-icon-sm bg-secondary">
                        <i class="fas fa-image"></i>
                    </div>
                    <div class="stat-info-sm">
                        <div class="stat-number-sm">{{stats.images}}</div>
                        <div class="stat-label-sm">صور</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="stat-card-sm">
                    <div class="stat-icon-sm bg-dark">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="stat-info-sm">
                        <div class="stat-number-sm">{{stats.total}}</div>
                        <div class="stat-label-sm">المجموع</div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- تبويبات المحتوى -->
        <div class="tabs-container">
            <div class="tabs-nav">
                <button class="tab-btn active" data-tab="video">
                    <i class="fas fa-video"></i> فيديو
                </button>
                <button class="tab-btn" data-tab="pdf">
                    <i class="fas fa-file-pdf"></i> PDF
                </button>
                <button class="tab-btn" data-tab="image">
                    <i class="fas fa-image"></i> صورة
                </button>
                <button class="tab-btn" data-tab="text">
                    <i class="fas fa-file-alt"></i> نص
                </button>
                <button class="tab-btn" data-tab="quiz">
                    <i class="fas fa-question-circle"></i> اختبار
                </button>
            </div>
            
            <div class="tabs-content">
                <!-- تبويب فيديو -->
                <div class="tab-pane active" id="tab-video">
                    <form id="videoForm">
                        <div class="form-group">
                            <label class="form-label">اختر الدرس <span class="text-danger">*</span></label>
                            <select class="form-select" name="lessonId" required>
                                <option value="">-- اختر درس --</option>
                                {{#each lessons}}
                                <option value="{{this._id}}">{{this.name}} - {{this.branchId.name}} - {{this.subjectId.name}}</option>
                                {{/each}}
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">عنوان الفيديو <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" placeholder="مثال: شرح الدرس الأول" required>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">نوع المصدر</label>
                            <div class="source-type-group">
                                <label class="source-option">
                                    <input type="radio" name="sourceType" value="upload" checked>
                                    <span class="source-option-content">
                                        <i class="fas fa-upload"></i>
                                        <span>رفع ملف</span>
                                    </span>
                                </label>
                                <label class="source-option">
                                    <input type="radio" name="sourceType" value="url">
                                    <span class="source-option-content">
                                        <i class="fab fa-vimeo"></i>
                                        <span>رابط Vimeo</span>
                                    </span>
                                </label>
                            </div>
                        </div>
                        
                        <!-- Zone Upload -->
                        <div id="videoUploadZone">
                            <div class="form-group">
                                <label class="form-label">الملف <span class="text-danger">*</span></label>
                                <div class="upload-zone" id="videoFileZone">
                                    <i class="fas fa-cloud-upload-alt fa-3x mb-2"></i>
                                    <p>اسحب الفيديو هنا أو انقر للاختيار</p>
                                    <small class="text-muted">MP4, WebM, AVI, MOV</small>
                                    <input type="file" accept="video/*" style="display:none;" id="videoFileInput">
                                </div>
                                <div id="videoProgress" class="progress-wrapper" style="display:none;">
                                    <div class="progress-info">
                                        <span id="videoFileName" class="progress-filename"></span>
                                        <span id="videoPercent">0%</span>
                                    </div>
                                    <div class="progress-bar-track">
                                        <div class="progress-bar-fill" id="videoProgressBar"></div>
                                    </div>
                                    <div id="videoStatus" class="progress-status"></div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Zone URL -->
                        <div id="videoUrlZone" style="display:none;">
                            <div class="form-group">
                                <label class="form-label">رابط الفيديو <span class="text-danger">*</span></label>
                                <input type="url" class="form-control" id="videoUrlInput" 
                                       placeholder="https://vimeo.com/123456789">
                                <div class="form-text small">أدخل رابط الفيديو من Vimeo</div>
                            </div>
                            <div id="videoPreviewContainer" style="display:none;">
                                <div class="preview-box">
                                    <div class="preview-header">
                                        <i class="fas fa-eye"></i> معاينة
                                    </div>
                                    <div class="ratio ratio-16x9">
                                        <iframe id="videoPreviewIframe" src="" frameborder="0" allowfullscreen></iframe>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">ترتيب العرض</label>
                            <input type="number" class="form-control" name="order" value="0" min="0">
                        </div>
                        
                        <div class="form-group">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" id="isReel" name="isReel">
                                <label class="custom-control-label" for="isReel">
                                    <i class="fab fa-tiktok"></i> هذا الفيديو هو Reel (فيديو قصير)
                                </label>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary" id="videoBtnSubmit">
                            <i class="fas fa-upload"></i> رفع الفيديو
                        </button>
                    </form>
                </div>

                <!-- تبويب PDF -->
                <div class="tab-pane" id="tab-pdf">
                    <form id="pdfForm">
                        <div class="form-group">
                            <label class="form-label">اختر الدرس <span class="text-danger">*</span></label>
                            <select class="form-select" name="lessonId" required>
                                <option value="">-- اختر درس --</option>
                                {{#each lessons}}
                                <option value="{{this._id}}">{{this.name}} - {{this.branchId.name}} - {{this.subjectId.name}}</option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">عنوان PDF <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" placeholder="مثال: ملخص الدرس" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">ملف PDF <span class="text-danger">*</span></label>
                            <div class="upload-zone" id="pdfUploadZone">
                                <i class="fas fa-file-pdf fa-3x mb-2 text-danger"></i>
                                <p>اسحب PDF هنا أو انقر للاختيار</p>
                                <small class="text-muted">PDF فقط</small>
                                <input type="file" accept=".pdf" style="display:none;" id="pdfFileInput">
                            </div>
                            <div id="pdfProgress" class="progress-wrapper" style="display:none;">
                                <div class="progress-info">
                                    <span id="pdfFileName" class="progress-filename"></span>
                                    <span id="pdfPercent">0%</span>
                                </div>
                                <div class="progress-bar-track">
                                    <div class="progress-bar-fill bg-danger" id="pdfProgressBar"></div>
                                </div>
                                <div id="pdfStatus" class="progress-status"></div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">ترتيب العرض</label>
                            <input type="number" class="form-control" name="order" value="0" min="0">
                        </div>
                        <button type="submit" class="btn btn-primary" id="pdfBtnSubmit">
                            <i class="fas fa-upload"></i> رفع PDF
                        </button>
                    </form>
                </div>

                <!-- تبويب صورة -->
                <div class="tab-pane" id="tab-image">
                    <form id="imageForm">
                        <div class="form-group">
                            <label class="form-label">اختر الدرس <span class="text-danger">*</span></label>
                            <select class="form-select" name="lessonId" required>
                                <option value="">-- اختر درس --</option>
                                {{#each lessons}}
                                <option value="{{this._id}}">{{this.name}} - {{this.branchId.name}} - {{this.subjectId.name}}</option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">عنوان الصورة <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" placeholder="مثال: رسم توضيحي" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">الصورة <span class="text-danger">*</span></label>
                            <div class="upload-zone" id="imageUploadZone">
                                <i class="fas fa-image fa-3x mb-2"></i>
                                <p>اسحب الصورة هنا أو انقر للاختيار</p>
                                <small class="text-muted">JPG, PNG, WebP, GIF</small>
                                <input type="file" accept="image/*" style="display:none;" id="imageFileInput">
                            </div>
                            <div id="imageProgress" class="progress-wrapper" style="display:none;">
                                <div class="progress-info">
                                    <span id="imageFileName" class="progress-filename"></span>
                                    <span id="imagePercent">0%</span>
                                </div>
                                <div class="progress-bar-track">
                                    <div class="progress-bar-fill bg-secondary" id="imageProgressBar"></div>
                                </div>
                                <div id="imageStatus" class="progress-status"></div>
                            </div>
                            <div id="imagePreviewContainer" style="display:none; margin-top:0.75rem;">
                                <img id="imagePreview" src="#" alt="معاينة" style="max-width:100%; border-radius:10px;">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">ترتيب العرض</label>
                            <input type="number" class="form-control" name="order" value="0" min="0">
                        </div>
                        <button type="submit" class="btn btn-primary" id="imageBtnSubmit">
                            <i class="fas fa-upload"></i> رفع الصورة
                        </button>
                    </form>
                </div>
                
                <!-- تبويب نص -->
                <div class="tab-pane" id="tab-text">
                    <form action="/content/upload/text" method="post">
                        <div class="form-group">
                            <label class="form-label">اختر الدرس <span class="text-danger">*</span></label>
                            <select class="form-select" name="lessonId" required>
                                <option value="">-- اختر درس --</option>
                                {{#each lessons}}
                                <option value="{{this._id}}">{{this.name}} - {{this.branchId.name}} - {{this.subjectId.name}}</option>
                                {{/each}}
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">عنوان المحتوى <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" required>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">المحتوى <span class="text-danger">*</span></label>
                            <textarea name="body" rows="10" class="form-control" placeholder="اكتب المحتوى هنا..."></textarea>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">ترتيب العرض</label>
                            <input type="number" class="form-control" name="order" value="0" min="0">
                        </div>
                        
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> حفظ النص
                        </button>
                    </form>
                </div>
                
                <!-- تبويب اختبار (simplifié) -->
                <div class="tab-pane" id="tab-quiz">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        يمكنك إنشاء الاختبارات من قسم "الاختبارات" في القائمة الجانبية.
                    </div>
                    <a href="/quiz" class="btn btn-primary">
                        <i class="fas fa-question-circle"></i> إدارة الاختبارات
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

