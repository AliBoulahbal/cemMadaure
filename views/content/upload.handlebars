<script>
// تبديل التبويبات
document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
});

// Gestion source vidéo
const sourceRadios = document.querySelectorAll('input[name="sourceType"]');
const uploadZoneDiv = document.getElementById('videoUploadZone');
const urlZoneDiv = document.getElementById('videoUrlZone');
const fileInput = document.getElementById('videoFileInput');
const urlInput = document.getElementById('videoUrlInput');

function updateSource() {
    const selected = document.querySelector('input[name="sourceType"]:checked').value;
    if (selected === 'upload') {
        uploadZoneDiv.style.display = 'block';
        urlZoneDiv.style.display = 'none';
        if (fileInput) fileInput.required = true;
        if (urlInput) urlInput.required = false;
    } else {
        uploadZoneDiv.style.display = 'none';
        urlZoneDiv.style.display = 'block';
        if (fileInput) fileInput.required = false;
        if (urlInput) urlInput.required = true;
    }
}

sourceRadios.forEach(r => r.addEventListener('change', updateSource));
updateSource();

// Aperçu Vimeo
if (urlInput) {
    urlInput.addEventListener('input', function() {
        const url = this.value;
        const previewDiv = document.getElementById('videoPreviewContainer');
        const iframe = document.getElementById('videoPreviewIframe');
        const match = url.match(/vimeo\.com\/(?:video\/)?(\d+)/i);
        
        if (match && match[1]) {
            iframe.src = 'https://player.vimeo.com/video/' + match[1] + '?autoplay=0';
            previewDiv.style.display = 'block';
        } else {
            previewDiv.style.display = 'none';
            iframe.src = '';
        }
    });
}

// Setup zones de drop
function setupZone(zoneId, inputId) {
    const zone = document.getElementById(zoneId);
    const input = document.getElementById(inputId);
    if (!zone || !input) return;
    zone.addEventListener('click', () => input.click());
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        input.files = e.dataTransfer.files;
        input.dispatchEvent(new Event('change'));
    });
}

setupZone('videoFileZone', 'videoFileInput');
setupZone('pdfUploadZone', 'pdfFileInput');
setupZone('imageUploadZone', 'imageFileInput');

// Upload vers Wasabi
async function uploadToWasabi(file, type, progressBar, percentEl, statusEl, progressWrapper) {
    const ext = file.name.split('.').pop().toLowerCase();
    statusEl.textContent = 'جاري التحضير...';
    progressWrapper.style.display = 'block';

    const res = await fetch('/content/presign?type=' + type + '&ext=' + ext);
    if (!res.ok) throw new Error('فشل الحصول على رابط الرفع');
    const data = await res.json();

    return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open('PUT', data.url);
        xhr.setRequestHeader('Content-Type', file.type || 'application/octet-stream');

        xhr.upload.addEventListener('progress', (e) => {
            if (e.lengthComputable) {
                const pct = Math.round((e.loaded / e.total) * 100);
                progressBar.style.width = pct + '%';
                percentEl.textContent = pct + '%';
                statusEl.textContent = pct < 100 ? 'جاري الرفع...' : 'اكتمل الرفع ✓';
            }
        });

        xhr.addEventListener('load', () => {
            if (xhr.status === 200) resolve(data.publicUrl);
            else reject(new Error('فشل رفع الملف'));
        });

        xhr.addEventListener('error', () => reject(new Error('خطأ في الاتصال')));
        xhr.send(file);
    });
}

// Submit vidéo
document.getElementById('videoForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const sourceType = document.querySelector('input[name="sourceType"]:checked').value;
    const lessonId = document.querySelector('#videoForm [name="lessonId"]').value;
    const title = document.querySelector('#videoForm [name="title"]').value;
    const order = document.querySelector('#videoForm [name="order"]').value;
    const isReel = document.querySelector('#isReel')?.checked || false;
    
    if (!lessonId || !title) {
        Swal.fire('خطأ', 'يرجى ملء جميع الحقول', 'error');
        return;
    }
    
    const btn = document.getElementById('videoBtnSubmit');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري المعالجة...';
    
    try {
        if (sourceType === 'url') {
            const videoUrl = urlInput.value;
            if (!videoUrl) throw new Error('يرجى إدخال رابط الفيديو');
            
            const response = await fetch('/content/upload/video-url', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ lessonId, title, order, videoUrl, isReel })
});
            const result = await response.json();
            if (!result.success) throw new Error(result.error);
            Swal.fire('✅', 'تم إضافة الفيديو بنجاح', 'success').then(() => location.reload());
        } else {
            const file = fileInput.files[0];
            if (!file) throw new Error('يرجى اختيار ملف فيديو');
            
            const publicUrl = await uploadToWasabi(
                file, 'video',
                document.getElementById('videoProgressBar'),
                document.getElementById('videoPercent'),
                document.getElementById('videoStatus'),
                document.getElementById('videoProgress')
            );
            
            const response = await fetch('/content/upload/video', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lessonId, title, order, fileUrl: publicUrl, isReel })
            });
            const result = await response.json();
            if (!result.success) throw new Error(result.error);
            Swal.fire('✅', 'تم رفع الفيديو بنجاح', 'success').then(() => location.reload());
        }
    } catch (err) {
        Swal.fire('خطأ', err.message, 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-upload"></i> رفع الفيديو';
    }
});

// Affichage noms fichiers
document.getElementById('videoFileInput')?.addEventListener('change', function() {
    if (this.files[0]) document.getElementById('videoFileName').textContent = this.files[0].name;
});
document.getElementById('pdfFileInput')?.addEventListener('change', function() {
    if (this.files[0]) document.getElementById('pdfFileName').textContent = this.files[0].name;
});
document.getElementById('imageFileInput')?.addEventListener('change', function() {
    if (!this.files[0]) return;
    document.getElementById('imageFileName').textContent = this.files[0].name;
    const reader = new FileReader();
    reader.onload = e => {
        document.getElementById('imagePreview').src = e.target.result;
        document.getElementById('imagePreviewContainer').style.display = 'block';
    };
    reader.readAsDataURL(this.files[0]);
});
</script>