}

// Gestionnaire d'édition
document.querySelectorAll('.edit, .action-icon.edit').forEach(btn => {
    btn.addEventListener('click', function(e) {
        e.preventDefault();
        
        const type = this.dataset.type;
        const id = this.dataset.id;
        const title = this.dataset.title;
        let contentData = null;
        
        // Récupérer les données du contenu
        if (this.dataset.content) {
            try {
                contentData = JSON.parse(this.dataset.content);
            } catch(e) {
                console.error('Erreur parsing content:', e);
            }
        }
        
        currentEditType = type;
        
        document.getElementById('editContentId').value = id;
        document.getElementById('editTitle').value = title || '';
        
        const dynamicFields = document.getElementById('editDynamicFields');
        
        // Générer les champs selon le type
        if (type === 'text') {
            dynamicFields.innerHTML = `
                <div class="form-group">
                    <label class="form-label">المحتوى <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="editTextBody" rows="10">${contentData?.data?.body || ''}</textarea>
                </div>
            `;
            setTimeout(() => {
                if (editorInstance) editorInstance.destroy();
                editorInstance = CKEDITOR.replace('editTextBody', {
                    height: 300,
                    language: 'ar',
                    contentsLangDirection: 'rtl'
                });
            }, 100);
        } 
        // Gestionnaire d'édition pour les images
else if (type === 'image') {
    dynamicFields.innerHTML = `
        <div class="form-group">
            <label class="form-label">URL de l'image <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="editImageUrl" value="${contentData?.data?.url || ''}" placeholder="https://example.com/image.jpg">
            <small class="form-text text-muted">لاحظ: /uploads/images/image-xxx.png</small>
        </div>
        <div class="form-group text-center" id="imagePreviewArea">
            ${contentData?.data?.url ? `<img src="${contentData.data.url}" style="max-width: 200px; border-radius: 8px; border: 1px solid #ddd; padding: 5px;">` : '<span class="text-muted">لا توجد معاينة</span>'}
        </div>
        <div class="alert alert-warning mt-2">
            <i class="fas fa-info-circle"></i> 
            <strong>Remarque:</strong> Le chemin doit commencer par /uploads/images/
        </div>
    `;
    
    const urlInput = document.getElementById('editImageUrl');
    if (urlInput) {
        // Nettoyer l'URL si nécessaire
        let currentUrl = urlInput.value;
        if (currentUrl && !currentUrl.startsWith('/uploads/')) {
            urlInput.value = '/uploads/images/' + currentUrl.split('/').pop();
        }
        
        urlInput.addEventListener('input', function() {
            let value = this.value;
            // Auto-correction du chemin
            if (value && !value.startsWith('/uploads/')) {
                if (value.includes('uploads/images/')) {
                    const parts = value.split('uploads/images/');
                    this.value = '/uploads/images/' + parts[parts.length - 1];
                }
            }
            
            const preview = document.getElementById('imagePreviewArea');
            if (this.value && this.value.trim()) {
                preview.innerHTML = `<img src="${this.value}" style="max-width: 200px; border-radius: 8px; border: 1px solid #ddd; padding: 5px;" onerror="this.src='https://placehold.co/200x150?text=Image+non+trouvée'">`;
            } else {
                preview.innerHTML = '<span class="text-muted">لا توجد معاينة</span>';
            }
        });
    }
}
        else if (type === 'video') {
            dynamicFields.innerHTML = `
                <div class="form-group">
                    <label class="form-label">URL de la vidéo <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="editVideoUrl" value="${contentData?.data?.url || ''}" placeholder="https://example.com/video.mp4">
                </div>
                <div class="form-group">
                    <label class="form-label">المدة (ثواني)</label>
                    <input type="number" class="form-control" id="editDuration" value="${contentData?.data?.duration || 0}">
                </div>
            `;
        } 
        else if (type === 'pdf') {
            dynamicFields.innerHTML = `
                <div class="form-group">
                    <label class="form-label">URL du PDF <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="editPdfUrl" value="${contentData?.data?.url || ''}" placeholder="https://example.com/document.pdf">
                </div>
            `;
        } 
        else if (type === 'quiz') {
            dynamicFields.innerHTML = `
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> 
                    لتعديل الاختبار، يرجى حذفه وإعادة إنشائه.
                </div>
            `;
        }
        
        $('#editContentModal').modal('show');
    });
});

// Sauvegarde des modifications - VERSION CORRIGÉE
document.getElementById('saveContentChanges')?.addEventListener('click', async function() {
    const contentId = document.getElementById('editContentId').value;
    const title = document.getElementById('editTitle').value.trim();
    
    // Validation du titre
    if (!title) {
        Swal.fire({ icon: 'error', title: 'خطأ', text: 'العنوان مطلوب' });
        return;
    }
    
    let data = {};
    let hasData = false;
    
    // Récupérer les données selon le type
    if (currentEditType === 'text') {
        const body = editorInstance ? editorInstance.getData() : document.getElementById('editTextBody')?.value;
        if (!body || body.trim() === '') {
            Swal.fire({ icon: 'error', title: 'خطأ', text: 'المحتوى مطلوب' });
            return;
        }
        data = { body: body };
        hasData = true;
    } 
    else if (currentEditType === 'image') {
        const url = document.getElementById('editImageUrl')?.value.trim();
        if (!url) {
            Swal.fire({ icon: 'error', title: 'خطأ', text: 'URL الصورة مطلوب' });
            return;
        }
        data = { url: url };
        hasData = true;
    } 
    else if (currentEditType === 'video') {
        const url = document.getElementById('editVideoUrl')?.value.trim();
        if (!url) {
            Swal.fire({ icon: 'error', title: 'خطأ', text: 'URL الفيديو مطلوب' });
            return;
        }
        data = { 
            url: url, 
            duration: parseInt(document.getElementById('editDuration')?.value) || 0 
        };
        hasData = true;
    } 
    else if (currentEditType === 'pdf') {
        const url = document.getElementById('editPdfUrl')?.value.trim();
        if (!url) {
            Swal.fire({ icon: 'error', title: 'خطأ', text: 'URL PDF مطلوب' });
            return;
        }
        data = { url: url };
        hasData = true;
    }
    
    if (!hasData && currentEditType !== 'quiz') {
        Swal.fire({ icon: 'error', title: 'خطأ', text: 'البيانات مطلوبة' });
        return;
    }
    
    const btn = this;
    const originalHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
    
    try {
        const response = await fetch(`/content/update/${contentId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, data })
        });
        const result = await response.json();
        
        if (result.success) {
            Swal.fire({ 
                icon: 'success', 
                title: 'تم!', 
                text: result.warning || 'تم تحديث المحتوى بنجاح',
                timer: 1500, 
                showConfirmButton: false 
            });
            $('#editContentModal').modal('hide');
            setTimeout(() => location.reload(), 1500);
        } else {
            Swal.fire({ icon: 'error', title: 'خطأ', text: result.error || 'Erreur lors de la mise à jour' });
        }
    } catch (error) {
        console.error('Erreur:', error);
        Swal.fire({ icon: 'error', title: 'خطأ', text: error.message });
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    }
});

// ============================================
// Approbation
// ============================================
document.querySelectorAll('.approve').forEach(btn => {
    btn.addEventListener('click', async function() {
        const result = await Swal.fire({
            title: 'تأكيد الموافقة',
            text: 'هل أنت متأكد من الموافقة على نشر هذا المحتوى؟',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'نعم، وافق',
            cancelButtonText: 'إلغاء'
        });
        
        if (result.isConfirmed) {
            try {
                const response = await fetch(`/approval/content/${this.dataset.id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'PUBLISHED' })
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire('تم!', 'تم نشر المحتوى', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    Swal.fire('خطأ', data.error, 'error');
                }
            } catch (error) {
                Swal.fire('خطأ', error.message, 'error');
            }
        }
    });
});

// ============================================
// Rejet
// ============================================
let currentRejectId = null;

document.querySelectorAll('.reject').forEach(btn => {
    btn.addEventListener('click', function() {
        currentRejectId = this.dataset.id;
        $('#rejectModal').modal('show');
    });
});

document.getElementById('confirmReject')?.addEventListener('click', async function() {
    const reason = document.getElementById('rejectionReason').value;
    if (!reason) {
        Swal.fire('خطأ', 'الرجاء إدخال سبب الرفض', 'error');
        return;
    }
    
    try {
        const response = await fetch(`/approval/content/${currentRejectId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'REJECTED', rejectionReason: reason })
        });
        const data = await response.json();
        if (data.success) {
            Swal.fire('تم!', 'تم رفض المحتوى', 'success');
            $('#rejectModal').modal('hide');
            setTimeout(() => location.reload(), 1500);
        } else {
            Swal.fire('خطأ', data.error, 'error');
        }
    } catch (error) {
        Swal.fire('خطأ', error.message, 'error');
    }
});

// Initialisation
document.addEventListener('DOMContentLoaded', function() {
    initSortable();
});
</script>