<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-primary-light">
                <i class="fas fa-plus-circle text-primary"></i>
            </div>
            <div>
                <h3 class="modern-title">إضافة مادة دراسية جديدة</h3>
                <p class="modern-subtitle">قم بتعبئة المعلومات التالية</p>
            </div>
        </div>
        <a href="/subject" class="modern-btn modern-btn-secondary">
            <i class="fas fa-arrow-right"></i> رجوع
        </a>
    </div>
    
    <div class="modern-card-body">
        {{#if error}}
        <div class="modern-alert modern-alert-danger">
            <i class="fas fa-exclamation-circle"></i> {{error}}
        </div>
        {{/if}}
        
        <form action="/subject/create" method="post" class="modern-form">
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="branchId" class="form-label">
                        السنة الدراسية <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-graduation-cap input-icon"></i>
                        <select class="modern-input" id="branchId" name="branchId" required>
                            <option value="">-- اختر السنة --</option>
                            {{#each branches}}
                            <option value="{{this._id}}" {{#if (eq this._id ../formData.branchId)}}selected{{/if}}>
                                {{this.name}}
                            </option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                
                <div class="form-group-modern">
                    <label for="name" class="form-label">
                        اسم المادة <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-book input-icon"></i>
                        <input type="text" class="modern-input" id="name" name="name" 
                               value="{{formData.name}}" placeholder="مثال: الرياضيات" required>
                    </div>
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="code" class="form-label">الرمز</label>
                    <div class="input-wrapper">
                        <i class="fas fa-barcode input-icon"></i>
                        <input type="text" class="modern-input" id="code" name="code" 
                               value="{{formData.code}}" placeholder="مثال: MATH01">
                    </div>
                    <span class="form-hint">رمز مختصر للمادة</span>
                </div>
                
                <div class="form-group-modern">
                    <label for="order" class="form-label">الترتيب</label>
                    <div class="input-wrapper">
                        <i class="fas fa-sort-numeric-down input-icon"></i>
                        <input type="number" class="modern-input" id="order" name="order" 
                               value="{{formData.order}}" placeholder="0" min="0">
                    </div>
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="icon" class="form-label">الأيقونة</label>
                    <div class="input-wrapper">
                        <i class="fas fa-icons input-icon"></i>
                        <select class="modern-input" id="icon" name="icon">
                            <option value="fa-book" {{#if (eq formData.icon 'fa-book')}}selected{{/if}}>📚 كتاب</option>
                            <option value="fa-calculator" {{#if (eq formData.icon 'fa-calculator')}}selected{{/if}}>🧮 آلة حاسبة</option>
                            <option value="fa-flask" {{#if (eq formData.icon 'fa-flask')}}selected{{/if}}>🧪 مختبر</option>
                            <option value="fa-language" {{#if (eq formData.icon 'fa-language')}}selected{{/if}}>🌐 لغة</option>
                            <option value="fa-music" {{#if (eq formData.icon 'fa-music')}}selected{{/if}}>🎵 موسيقى</option>
                            <option value="fa-paintbrush" {{#if (eq formData.icon 'fa-paintbrush')}}selected{{/if}}>🎨 رسم</option>
                            <option value="fa-futbol" {{#if (eq formData.icon 'fa-futbol')}}selected{{/if}}>⚽ رياضة</option>
                            <option value="fa-microscope" {{#if (eq formData.icon 'fa-microscope')}}selected{{/if}}>🔬 مجهر</option>
                        </select>
                    </div>
                </div>
                
                <div class="form-group-modern">
                    <label for="color" class="form-label">اللون</label>
                    <div class="input-wrapper">
                        <i class="fas fa-palette input-icon"></i>
                        <select class="modern-input" id="color" name="color">
                            <option value="primary" {{#if (eq formData.color 'primary')}}selected{{/if}}>🔵 أزرق</option>
                            <option value="success" {{#if (eq formData.color 'success')}}selected{{/if}}>🟢 أخضر</option>
                            <option value="danger" {{#if (eq formData.color 'danger')}}selected{{/if}}>🔴 أحمر</option>
                            <option value="warning" {{#if (eq formData.color 'warning')}}selected{{/if}}>🟡 أصفر</option>
                            <option value="info" {{#if (eq formData.color 'info')}}selected{{/if}}>🔵 سماوي</option>
                            <option value="purple" {{#if (eq formData.color 'purple')}}selected{{/if}}>🟣 بنفسجي</option>
                            <option value="pink" {{#if (eq formData.color 'pink')}}selected{{/if}}>🌸 وردي</option>
                            <option value="orange" {{#if (eq formData.color 'orange')}}selected{{/if}}>🟠 برتقالي</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="form-group-modern">
                <label for="description" class="form-label">الوصف</label>
                <div class="input-wrapper">
                    <i class="fas fa-align-right input-icon textarea-icon"></i>
                    <textarea class="modern-input modern-textarea" id="description" name="description" 
                              rows="4" placeholder="وصف مختصر للمادة...">{{formData.description}}</textarea>
                </div>
            </div>
            
            <div class="modern-info-box">
                <i class="fas fa-info-circle"></i>
                <div>
                    <strong>ملاحظة:</strong> بعد إضافة المادة، يمكنك إضافة الوحدات والدروس لها.
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="modern-btn modern-btn-primary">
                    <i class="fas fa-save"></i> حفظ المادة
                </button>
                <button type="reset" class="modern-btn modern-btn-secondary">
                    <i class="fas fa-undo"></i> إعادة تعيين
                </button>
            </div>
        </form>
    </div>
</div>
<style>
    /* RTL Base */
* {
    direction: rtl;
    text-align: right;
}

:root {
    --primary: #6366f1;
    --primary-dark: #4f46e5;
    --primary-light: #eef2ff;
    --success: #10b981;
    --success-light: #d1fae5;
    --warning: #f59e0b;
    --warning-light: #fef3c7;
    --danger: #ef4444;
    --danger-light: #fee2e2;
    --info: #3b82f6;
    --info-light: #dbeafe;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --gray-900: #111827;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
}

/* Modern Card */
.modern-card {
    background: white;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    margin: 1.5rem;
}

.modern-card-header {
    padding: 1.5rem 2rem;
    background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
}

.modern-title-section {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.modern-icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
}

.bg-primary-light { background: var(--primary-light); }
.bg-warning-light { background: var(--warning-light); }
.bg-success-light { background: var(--success-light); }

.modern-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gray-800);
    margin: 0 0 0.25rem 0;
}

.modern-subtitle {
    font-size: 0.875rem;
    color: var(--gray-500);
    margin: 0;
}

.modern-card-body {
    padding: 2rem;
}

/* Form Styles */
.modern-form {
    max-width: 100%;
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}

@media (max-width: 768px) {
    .form-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
    }
}

.form-group-modern {
    margin-bottom: 0;
}

.form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gray-700);
    margin-bottom: 0.5rem;
}

.required {
    color: var(--danger);
}

.input-wrapper {
    position: relative;
}

.input-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    font-size: 1rem;
    pointer-events: none;
}

.textarea-icon {
    top: 1rem;
    transform: none;
}

.modern-input {
    width: 100%;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--gray-700);
    background: white;
    transition: all 0.2s ease;
}

.modern-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-light);
}

.modern-textarea {
    padding: 1rem 2.5rem 1rem 1rem;
    resize: vertical;
}

.form-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--gray-400);
    margin-top: 0.375rem;
}

/* Alert Styles */
.modern-alert {
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
}

.modern-alert-danger {
    background: var(--danger-light);
    color: var(--danger);
    border-right: 3px solid var(--danger);
}

.modern-info-box {
    background: var(--info-light);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    border-right: 3px solid var(--info);
    color: var(--info);
    font-size: 0.875rem;
}

.modern-info-box i {
    font-size: 1.25rem;
    margin-top: 0.125rem;
}

/* Button Styles */
.modern-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    text-decoration: none;
}

.modern-btn-primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    box-shadow: var(--shadow-sm);
}

.modern-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    color: white;
}

.modern-btn-secondary {
    background: var(--gray-100);
    color: var(--gray-600);
    border: 1px solid var(--gray-200);
}

.modern-btn-secondary:hover {
    background: var(--gray-200);
    color: var(--gray-700);
}

.form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--gray-200);
}

/* Filter Section */
.filter-section {
    background: var(--gray-50);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: flex-start;
}

.filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.filter-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gray-600);
}

.modern-filter {
    padding: 0.5rem 2rem 0.5rem 1rem;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    background: white;
    font-size: 0.875rem;
    min-width: 200px;
}

/* Table Styles */
.table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200);
}

.modern-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.modern-table thead {
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-200);
}

.modern-table th {
    padding: 1rem 1.25rem;
    font-weight: 600;
    color: var(--gray-600);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.modern-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--gray-100);
    color: var(--gray-700);
}

.modern-table tbody tr:hover {
    background: var(--gray-50);
}

/* Subject Info */
.subject-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.subject-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
}

.subject-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.subject-desc {
    font-size: 0.75rem;
    color: var(--gray-400);
}

/* Badges */
.badge-modern {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 500;
}

.badge-branch {
    background: var(--info-light);
    color: var(--info);
}

.badge-pending {
    background: var(--warning-light);
    color: var(--warning);
    font-size: 0.7rem;
    padding: 0.125rem 0.5rem;
}

.code-badge {
    background: var(--gray-100);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--gray-600);
}

.order-badge {
    background: var(--gray-100);
    padding: 0.25rem 0.75rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--gray-600);
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    text-decoration: none;
}

.action-edit {
    background: var(--warning-light);
    color: var(--warning);
}

.action-edit:hover {
    background: var(--warning);
    color: white;
}

.action-delete {
    background: var(--danger-light);
    color: var(--danger);
}

.action-delete:hover {
    background: var(--danger);
    color: white;
}

.action-approve {
    background: var(--success-light);
    color: var(--success);
}

.action-approve:hover {
    background: var(--success);
    color: white;
}

.action-reject {
    background: var(--danger-light);
    color: var(--danger);
}

.action-reject:hover {
    background: var(--danger);
    color: white;
}

/* Creator & Date Info */
.creator-info, .date-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.creator-name {
    font-weight: 500;
    color: var(--gray-700);
}

.creator-username {
    font-size: 0.7rem;
    color: var(--gray-400);
}

.date-info {
    color: var(--gray-500);
    font-size: 0.75rem;
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 3rem 2rem;
}

.empty-icon {
    font-size: 3rem;
    color: var(--gray-300);
    margin-bottom: 1rem;
}

.empty-state h4 {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--gray-600);
    margin-bottom: 0.5rem;
}

.empty-description {
    color: var(--gray-400);
    font-size: 0.875rem;
}

/* Utility */
.text-primary { color: var(--primary); }
.text-warning { color: var(--warning); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-center { text-align: center; }

.col-number { width: 50px; }
.col-actions { width: 150px; }

/* Responsive */
@media (max-width: 768px) {
    .modern-card {
        margin: 1rem;
    }
    
    .modern-card-header,
    .modern-card-body {
        padding: 1rem;
    }
    
    .modern-table th,
    .modern-table td {
        padding: 0.75rem;
    }
    
    .action-btn span {
        display: none;
    }
    
    .action-btn {
        padding: 0.5rem;
    }
}
</style>