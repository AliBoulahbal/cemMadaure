<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-warning-light">
                <i class="fas fa-clock text-warning"></i>
            </div>
            <div>
                <h3 class="modern-title">الدروس قيد المراجعة</h3>
                <p class="modern-subtitle">مراجعة الدروس المنتظرة للنشر</p>
            </div>
        </div>
        <a href="/lesson" class="modern-btn modern-btn-secondary">
            <i class="fas fa-arrow-right"></i> رجوع
        </a>
    </div>
    
    <div class="modern-card-body">
        {{#if lessons.length}}
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon bg-warning-light">
                    <i class="fas fa-hourglass-half text-warning"></i>
                </div>
                <div class="stat-value">{{lessons.length}}</div>
                <div class="stat-label">درس قيد المراجعة</div>
            </div>
        </div>
        
        <div class="table-wrapper">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>الدرس</th>
                        <th>المادة</th>
                        <th>السنة</th>
                        <th>الوحدة</th>
                        <th>المنشئ</th>
                        <th>تاريخ الإنشاء</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each lessons}}
                    <tr id="row-{{this._id}}">
                        <td>
                            <div class="lesson-info">
                                <div class="lesson-icon pending-icon">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="lesson-details">
                                    <strong>{{this.name}}</strong>
                                    <span class="badge-modern badge-pending">قيد المراجعة</span>
                                </div>
                            </div>
                        </td>
                        <td>{{this.subjectId.name}}</td>
                        <td>{{this.branchId.name}}</td>
                        <td>{{this.unitId.name}}</td>
                        <td>
                            <div class="creator-info">
                                <i class="fas fa-user-circle"></i>
                                <div>
                                    <div class="creator-name">{{this.createdBy.fullName}}</div>
                                    <div class="creator-username">{{this.createdBy.username}}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="date-info">
                                <i class="fas fa-calendar-alt"></i>
                                <span>{{formatDate this.createdAt}}</span>
                            </div>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <button class="action-btn action-approve" data-id="{{this._id}}" data-name="{{this.name}}">
                                    <i class="fas fa-check-circle"></i>
                                    <span>موافقة</span>
                                </button>
                                <button class="action-btn action-reject" data-id="{{this._id}}" data-name="{{this.name}}">
                                    <i class="fas fa-times-circle"></i>
                                    <span>رفض</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h4>لا توجد دروس في انتظار المراجعة</h4>
            <p class="empty-description">جميع الدروس قد تمت مراجعتها ونشرها</p>
        </div>
        {{/if}}
    </div>
</div>

<style>
    * { direction: rtl; text-align: right; }
    
    :root {
        --primary: #6366f1;
        --primary-light: #eef2ff;
        --success: #10b981;
        --success-light: #d1fae5;
        --warning: #f59e0b;
        --warning-light: #fef3c7;
        --danger: #ef4444;
        --danger-light: #fee2e2;
        --info: #3b82f6;
        --info-light: #dbeafe;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.5rem;
        --radius-lg: 0.75rem;
        --radius-xl: 1rem;
    }
    
    .modern-card {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin: 1.5rem;
    }
    
    .modern-card-header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .modern-title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .modern-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-warning-light { background: var(--warning-light); }
    .text-warning { color: var(--warning); }
    
    .modern-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }
    
    .modern-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
        margin: 0;
    }
    
    .modern-card-body {
        padding: 2rem;
    }
    
    .stats-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    
    .stat-card {
        flex: 1;
        min-width: 150px;
        background: white;
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        text-align: center;
        border: 1px solid var(--gray-200);
        box-shadow: var(--shadow-sm);
    }
    
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.75rem;
        font-size: 1.25rem;
    }
    
    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--gray-800);
    }
    
    .stat-label {
        font-size: 0.75rem;
        color: var(--gray-500);
        margin-top: 0.25rem;
    }
    
    .table-wrapper {
        overflow-x: auto;
        border-radius: var(--radius-lg);
        border: 1px solid var(--gray-200);
    }
    
    .modern-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }
    
    .modern-table thead {
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
    }
    
    .modern-table th {
        padding: 1rem;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.75rem;
        text-transform: uppercase;
    }
    
    .modern-table td {
        padding: 1rem;
        border-bottom: 1px solid var(--gray-100);
        color: var(--gray-700);
        vertical-align: middle;
    }
    
    .modern-table tbody tr:hover {
        background: var(--gray-50);
    }
    
    .lesson-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .lesson-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--warning-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--warning);
    }
    
    .lesson-details {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .badge-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 500;
        width: fit-content;
    }
    
    .badge-pending {
        background: var(--warning-light);
        color: var(--warning);
    }
    
    .creator-info, .date-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .creator-name {
        font-weight: 500;
        color: var(--gray-700);
    }
    
    .creator-username {
        font-size: 0.7rem;
        color: var(--gray-400);
    }
    
    .date-info {
        color: var(--gray-500);
        font-size: 0.75rem;
    }
    
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-md);
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        text-decoration: none;
    }
    
    .action-approve {
        background: var(--success-light);
        color: var(--success);
    }
    
    .action-approve:hover {
        background: var(--success);
        color: white;
    }
    
    .action-reject {
        background: var(--danger-light);
        color: var(--danger);
    }
    
    .action-reject:hover {
        background: var(--danger);
        color: white;
    }
    
    .modern-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
    }
    
    .modern-btn-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }
    
    .modern-btn-secondary:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
    }
    
    .empty-icon {
        font-size: 3rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
    }
    
    .empty-state h4 {
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--gray-600);
        margin-bottom: 0.5rem;
    }
    
    .empty-description {
        color: var(--gray-400);
        font-size: 0.875rem;
    }
    
    @media (max-width: 768px) {
        .modern-card {
            margin: 1rem;
        }
        .modern-card-header,
        .modern-card-body {
            padding: 1rem;
        }
        .action-btn span {
            display: none;
        }
        .action-btn {
            padding: 0.5rem;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.querySelectorAll('.action-approve').forEach(btn => {
    btn.addEventListener('click', async function() {
        const lessonId = this.dataset.id;
        const lessonName = this.dataset.name;
        
        const result = await Swal.fire({
            title: 'تأكيد الموافقة',
            text: `هل أنت متأكد من الموافقة على نشر "${lessonName}"؟`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'نعم، وافق',
            cancelButtonText: 'إلغاء'
        });
        
        if (result.isConfirmed) {
            try {
                const response = await fetch(`/lesson/approve/${lessonId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire('تم!', 'تم نشر الدرس بنجاح', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    Swal.fire('خطأ', data.error, 'error');
                }
            } catch (error) {
                Swal.fire('خطأ', error.message, 'error');
            }
        }
    });
});

document.querySelectorAll('.action-reject').forEach(btn => {
    btn.addEventListener('click', async function() {
        const lessonId = this.dataset.id;
        const lessonName = this.dataset.name;
        
        const { value: reason, isConfirmed } = await Swal.fire({
            title: 'رفض الدرس',
            text: `هل تريد رفض "${lessonName}"؟`,
            input: 'textarea',
            inputLabel: 'سبب الرفض',
            inputPlaceholder: 'اكتب سبب الرفض هنا...',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'نعم، ارفض',
            cancelButtonText: 'إلغاء'
        });
        
        if (isConfirmed) {
            try {
                const response = await fetch(`/lesson/reject/${lessonId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rejectionReason: reason || '' })
                });
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire('تم!', 'تم رفض الدرس', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    Swal.fire('خطأ', data.error, 'error');
                }
            } catch (error) {
                Swal.fire('خطأ', error.message, 'error');
            }
        }
    });
});
</script>