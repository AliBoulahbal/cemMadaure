<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-primary-light">
                <i class="fas fa-chalkboard-teacher text-primary"></i>
            </div>
            <div>
                <h3 class="modern-title">قائمة الدروس</h3>
                <p class="modern-subtitle">إدارة وعرض جميع الدروس التعليمية</p>
            </div>
        </div>
        <a href="/lesson/create" class="modern-btn modern-btn-primary">
            <i class="fas fa-plus"></i> إضافة درس
        </a>
    </div>
    
    <div class="modern-card-body">
        <!-- Filters -->
        <div class="filter-section">
            <div class="filter-group">
                <label class="filter-label">
                    <i class="fas fa-filter"></i> السنة
                </label>
                <select class="modern-filter" id="filterBranch">
                    <option value="">جميع السنوات</option>
                    {{#each branches}}
                    <option value="{{this._id}}">{{this.name}}</option>
                    {{/each}}
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">
                    <i class="fas fa-book"></i> المادة
                </label>
                <select class="modern-filter" id="filterSubject">
                    <option value="">جميع المواد</option>
                    {{#each subjects}}
                    <option value="{{this._id}}">{{this.name}}</option>
                    {{/each}}
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">
                    <i class="fas fa-layer-group"></i> الوحدة
                </label>
                <select class="modern-filter" id="filterUnit">
                    <option value="">جميع الوحدات</option>
                    {{#each units}}
                    <option value="{{this._id}}">{{this.name}}</option>
                    {{/each}}
                </select>
            </div>
            <div class="filter-actions">
                <button id="resetFilters" class="modern-btn modern-btn-sm modern-btn-secondary">
                    <i class="fas fa-undo"></i> إعادة تعيين
                </button>
            </div>
        </div>
        
        <!-- Stats -->
        <div class="stats-banner" id="statsBanner" style="display: none;">
            <div class="stats-banner-content">
                <i class="fas fa-chart-line"></i>
                <span id="filteredCount">0</span> درس من أصل <span id="totalCount">0</span>
            </div>
        </div>
        
        <div class="table-wrapper">
            <table class="modern-table" id="lessonsTable">
                <thead>
                    <tr>
                        <th class="col-number">#</th>
                        <th class="col-lesson">الدرس</th>
                        <th class="col-branch">السنة</th>
                        <th class="col-subject">المادة</th>
                        <th class="col-unit">الوحدة</th>
                        <th class="col-order">الترتيب</th>
                        <th class="col-free">مجاني</th>
                        <th class="col-actions">إجراءات</th>
                        <th class="col-quiz">الاختبارات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each lessons}}
                    <tr data-branch="{{this.branchId._id}}" data-subject="{{this.subjectId._id}}" data-unit="{{this.unitId._id}}">
                        <td class="text-center">{{inc @index}}</td>
                        <td>
                            <div class="lesson-info">
                                <div class="lesson-icon">
                                    <i class="fas fa-play-circle"></i>
                                </div>
                                <div class="lesson-details">
                                    <strong>{{this.name}}</strong>
                                    {{#if this.description}}
                                    <span class="lesson-desc">{{this.description}}</span>
                                    {{/if}}
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge-modern badge-branch">
                                <i class="fas fa-calendar-alt"></i> {{this.branchId.name}}
                            </span>
                        </td>
                        <td>
                            <span class="badge-modern badge-subject">
                                <i class="fas fa-book"></i> {{this.subjectId.name}}
                            </span>
                        </td>
                        <td>
                            <span class="badge-modern badge-unit">
                                <i class="fas fa-layer-group"></i> {{this.unitId.name}}
                            </span>
                        </td>
                        <td class="text-center">
                            <span class="order-badge">{{this.order}}</span>
                        </td>
                        <td class="text-center">
                            {{#if this.isFree}}
                            <span class="badge-free">
                                <i class="fas fa-gift"></i> مجاني
                            </span>
                            {{else}}
                            <span class="badge-paid">
                                <i class="fas fa-lock"></i> مدفوع
                            </span>
                            {{/if}}
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a href="/lesson/view/{{this._id}}" class="action-btn action-view" title="عرض">
                                    <i class="fas fa-eye"></i>
                                    <span>عرض</span>
                                </a>
                                <a href="/lesson/edit/{{this._id}}" class="action-btn action-edit" title="تعديل">
                                    <i class="fas fa-edit"></i>
                                    <span>تعديل</span>
                                </a>
                                <form action="/lesson/delete/{{this._id}}?_method=DELETE" method="post" style="display: inline;">
                                    <button type="submit" class="action-btn action-delete delete-btn" title="حذف" onclick="return confirm('هل أنت متأكد من حذف هذا الدرس؟')">
                                        <i class="fas fa-trash"></i>
                                        <span>حذف</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="quiz-buttons">
                                <a href="/quiz/lesson/{{this._id}}" class="quiz-btn quiz-view" title="عرض الاختبارات">
                                    <i class="fas fa-question-circle"></i>
                                    <span>الاختبارات</span>
                                </a>
                                <a href="/quiz/create/{{this._id}}" class="quiz-btn quiz-add" title="إضافة اختبار">
                                    <i class="fas fa-plus"></i>
                                    <span>إضافة</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <i class="fas fa-chalkboard-teacher"></i>
                                <p>لا توجد دروس</p>
                                <a href="/lesson/create" class="modern-btn modern-btn-primary">أضف درساً الآن</a>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    * { direction: rtl; text-align: right; }
    
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #eef2ff;
        --success: #10b981;
        --success-light: #d1fae5;
        --warning: #f59e0b;
        --warning-light: #fef3c7;
        --danger: #ef4444;
        --danger-light: #fee2e2;
        --info: #3b82f6;
        --info-light: #dbeafe;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.5rem;
        --radius-lg: 0.75rem;
        --radius-xl: 1rem;
    }
    
    .modern-card {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin: 1.5rem;
    }
    
    .modern-card-header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .modern-title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .modern-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-primary-light { background: var(--primary-light); }
    .text-primary { color: var(--primary); }
    
    .modern-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }
    
    .modern-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
        margin: 0;
    }
    
    .modern-card-body {
        padding: 2rem;
    }
    
    .filter-section {
        background: var(--gray-50);
        padding: 1rem 1.5rem;
        border-radius: var(--radius-lg);
        margin-bottom: 1rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: flex-end;
    }
    
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
        min-width: 150px;
    }
    
    .filter-label {
        font-size: 0.8125rem;
        font-weight: 700;
        color: var(--gray-600);
    }
    
    .filter-label i {
        margin-left: 0.25rem;
        font-size: 0.75rem;
    }
    
    .modern-filter {
        padding: 0.6rem 1rem;
        border: 1.5px solid var(--gray-200);
        border-radius: var(--radius-md);
        background: white;
        font-size: 0.875rem;
        width: 100%;
        transition: all 0.2s ease;
    }
    
    .modern-filter:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-light);
    }
    
    .filter-actions {
        display: flex;
        align-items: center;
    }
    
    .modern-btn-sm {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
    }
    
    .stats-banner {
        background: var(--primary-light);
        border-radius: var(--radius-md);
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    .stats-banner-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--primary);
    }
    
    .table-wrapper {
        overflow-x: auto;
        border-radius: var(--radius-lg);
        border: 1px solid var(--gray-200);
    }
    
    .modern-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }
    
    .modern-table thead {
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
    }
    
    .modern-table th {
        padding: 1rem 1rem;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .modern-table td {
        padding: 1rem 1rem;
        border-bottom: 1px solid var(--gray-100);
        color: var(--gray-700);
    }
    
    .modern-table tbody tr:hover {
        background: var(--gray-50);
    }
    
    .lesson-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .lesson-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--primary-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
    }
    
    .lesson-details {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .lesson-desc {
        font-size: 0.7rem;
        color: var(--gray-400);
        max-width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .badge-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 500;
    }
    
    .badge-branch {
        background: var(--info-light);
        color: var(--info);
    }
    
    .badge-subject {
        background: var(--success-light);
        color: var(--success);
    }
    
    .badge-unit {
        background: var(--warning-light);
        color: var(--warning);
    }
    
    .order-badge {
        background: var(--gray-100);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--gray-600);
        display: inline-block;
    }
    
    .badge-free {
        background: var(--success-light);
        color: var(--success);
        padding: 0.25rem 0.5rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }
    
    .badge-paid {
        background: var(--gray-100);
        color: var(--gray-500);
        padding: 0.25rem 0.5rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }
    
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-md);
        font-size: 0.7rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        text-decoration: none;
    }
    
    .action-view {
        background: var(--info-light);
        color: var(--info);
    }
    
    .action-view:hover {
        background: var(--info);
        color: white;
    }
    
    .action-edit {
        background: var(--warning-light);
        color: var(--warning);
    }
    
    .action-edit:hover {
        background: var(--warning);
        color: white;
    }
    
    .action-delete {
        background: var(--danger-light);
        color: var(--danger);
    }
    
    .action-delete:hover {
        background: var(--danger);
        color: white;
    }
    
    .quiz-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .quiz-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.6rem;
        border-radius: var(--radius-md);
        font-size: 0.7rem;
        text-decoration: none;
        transition: all 0.2s ease;
    }
    
    .quiz-view {
        background: var(--primary-light);
        color: var(--primary);
    }
    
    .quiz-view:hover {
        background: var(--primary);
        color: white;
    }
    
    .quiz-add {
        background: var(--success-light);
        color: var(--success);
    }
    
    .quiz-add:hover {
        background: var(--success);
        color: white;
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
    }
    
    .empty-state i {
        font-size: 3rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
        display: inline-block;
    }
    
    .empty-state p {
        color: var(--gray-500);
        margin-bottom: 1rem;
    }
    
    .modern-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
    }
    
    .modern-btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        box-shadow: var(--shadow-sm);
    }
    
    .modern-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .modern-btn-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }
    
    .modern-btn-secondary:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }
    
    .col-number { width: 40px; }
    .col-order { width: 60px; }
    .col-free { width: 70px; }
    .col-actions { width: 160px; }
    .col-quiz { width: 130px; }
    
    .text-center { text-align: center; }
    
    @media (max-width: 1024px) {
        .col-actions span, .col-quiz span {
            display: none;
        }
        .action-btn, .quiz-btn {
            padding: 0.4rem;
        }
    }
    
    @media (max-width: 768px) {
        .modern-card {
            margin: 1rem;
        }
        .modern-card-header,
        .modern-card-body {
            padding: 1rem;
        }
        .filter-section {
            flex-direction: column;
            gap: 0.75rem;
        }
        .filter-group {
            width: 100%;
        }
        .filter-actions {
            width: 100%;
        }
        .filter-actions button {
            width: 100%;
            justify-content: center;
        }
        .modern-table th,
        .modern-table td {
            padding: 0.6rem;
        }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterBranch = document.getElementById('filterBranch');
    const filterSubject = document.getElementById('filterSubject');
    const filterUnit = document.getElementById('filterUnit');
    const resetBtn = document.getElementById('resetFilters');
    const statsBanner = document.getElementById('statsBanner');
    const filteredCountSpan = document.getElementById('filteredCount');
    const totalCountSpan = document.getElementById('totalCount');
    
    function filterTable() {
        const branchId = filterBranch?.value || '';
        const subjectId = filterSubject?.value || '';
        const unitId = filterUnit?.value || '';
        const rows = document.querySelectorAll('#lessonsTable tbody tr');
        
        let visibleCount = 0;
        let totalCount = 0;
        
        rows.forEach(row => {
            // Skip empty state row
            if (row.querySelector('.empty-state')) return;
            
            totalCount++;
            const rowBranch = row.getAttribute('data-branch');
            const rowSubject = row.getAttribute('data-subject');
            const rowUnit = row.getAttribute('data-unit');
            let show = true;
            
            if (branchId && rowBranch !== branchId) show = false;
            if (subjectId && rowSubject !== subjectId) show = false;
            if (unitId && rowUnit !== unitId) show = false;
            
            if (show) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
        
        if (totalCountSpan) totalCountSpan.textContent = totalCount;
        if (filteredCountSpan) filteredCountSpan.textContent = visibleCount;
        
        const hasFilter = branchId || subjectId || unitId;
        if (statsBanner) {
            statsBanner.style.display = hasFilter && totalCount > 0 ? 'flex' : 'none';
        }
    }
    
    if (filterBranch) filterBranch.addEventListener('change', filterTable);
    if (filterSubject) filterSubject.addEventListener('change', filterTable);
    if (filterUnit) filterUnit.addEventListener('change', filterTable);
    
    if (resetBtn) {
        resetBtn.addEventListener('click', function() {
            if (filterBranch) filterBranch.value = '';
            if (filterSubject) filterSubject.value = '';
            if (filterUnit) filterUnit.value = '';
            filterTable();
        });
    }
    
    // Initial total count
    const totalRows = document.querySelectorAll('#lessonsTable tbody tr:not(:has(.empty-state))').length;
    if (totalCountSpan) totalCountSpan.textContent = totalRows;
    
    // Animation
    const rows = document.querySelectorAll('#lessonsTable tbody tr');
    rows.forEach((row, index) => {
        if (!row.querySelector('.empty-state')) {
            row.style.opacity = '0';
            row.style.transform = 'translateY(10px)';
            setTimeout(() => {
                row.style.transition = 'all 0.3s ease';
                row.style.opacity = '1';
                row.style.transform = 'translateY(0)';
            }, index * 30);
        }
    });
});
</script>