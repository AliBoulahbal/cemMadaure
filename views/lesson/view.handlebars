<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-info-light">
                <i class="fas fa-chalkboard-teacher text-info"></i>
            </div>
            <div>
                <h3 class="modern-title">{{lesson.name}}</h3>
                <p class="modern-subtitle">عرض تفاصيل الدرس والمحتوى المرتبط به</p>
            </div>
        </div>
        <div class="header-actions">
            <a href="/lesson" class="modern-btn modern-btn-secondary">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
            <a href="/lesson/edit/{{lesson._id}}" class="modern-btn modern-btn-warning">
                <i class="fas fa-edit"></i> تعديل
            </a>
            <a href="/content/manage/{{lesson._id}}" class="modern-btn modern-btn-info">
                <i class="fas fa-file-alt"></i> إدارة المحتوى
            </a>
        </div>
    </div>
    
    <div class="modern-card-body">
        <div class="info-grid">
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-heading"></i> اسم الدرس
                </div>
                <div class="info-value">{{lesson.name}}</div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-graduation-cap"></i> السنة الدراسية
                </div>
                <div class="info-value">
                    {{#if lesson.branchId}}
                        <span class="badge-modern badge-branch">{{lesson.branchId.name}}</span>
                    {{else}}
                        <span class="text-muted">غير محدد</span>
                    {{/if}}
                </div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-book"></i> المادة
                </div>
                <div class="info-value">
                    {{#if lesson.subjectId}}
                        <span class="badge-modern badge-subject">{{lesson.subjectId.name}}</span>
                    {{else}}
                        <span class="text-muted">غير محدد</span>
                    {{/if}}
                </div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-layer-group"></i> الوحدة
                </div>
                <div class="info-value">
                    {{#if lesson.unitId}}
                        <span class="badge-modern badge-unit">{{lesson.unitId.name}}</span>
                    {{else}}
                        <span class="text-muted">غير محدد</span>
                    {{/if}}
                </div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-sort-numeric-down"></i> الترتيب
                </div>
                <div class="info-value">
                    <span class="order-badge">{{lesson.order}}</span>
                </div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-gift"></i> نوع الدرس
                </div>
                <div class="info-value">
                    {{#if lesson.isFree}}
                        <span class="badge-free">
                            <i class="fas fa-gift"></i> مجاني للجميع
                        </span>
                    {{else}}
                        <span class="badge-paid">
                            <i class="fas fa-lock"></i> للمشتركين فقط
                        </span>
                    {{/if}}
                </div>
            </div>
            
            <div class="info-card full-width">
                <div class="info-label">
                    <i class="fas fa-align-right"></i> وصف الدرس
                </div>
                <div class="info-value description-text">
                    {{#if lesson.description}}
                        {{lesson.description}}
                    {{else}}
                        <span class="text-muted">لا يوجد وصف</span>
                    {{/if}}
                </div>
            </div>
        </div>
        
        <div class="content-section">
            <div class="section-header">
                <div class="section-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <h4 class="section-title">المحتوى التعليمي</h4>
                <a href="/content/manage/{{lesson._id}}" class="modern-btn modern-btn-sm modern-btn-primary">
                    <i class="fas fa-plus"></i> إضافة محتوى
                </a>
            </div>
            <div class="modern-info-box">
                <i class="fas fa-info-circle"></i>
                <div>
                    <strong>ملاحظة:</strong> يمكنك إضافة محتوى تعليمي لهذا الدرس من خلال زر "إدارة المحتوى". يمكنك إضافة فيديوهات، ملفات PDF، نصوص تعليمية، واختبارات.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    * { direction: rtl; text-align: right; }
    
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #eef2ff;
        --success: #10b981;
        --success-light: #d1fae5;
        --warning: #f59e0b;
        --warning-light: #fef3c7;
        --danger: #ef4444;
        --danger-light: #fee2e2;
        --info: #3b82f6;
        --info-light: #dbeafe;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.5rem;
        --radius-lg: 0.75rem;
        --radius-xl: 1rem;
    }
    
    .modern-card {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin: 1.5rem;
    }
    
    .modern-card-header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .header-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    
    .modern-title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .modern-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-info-light { background: var(--info-light); }
    .text-info { color: var(--info); }
    
    .modern-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }
    
    .modern-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
