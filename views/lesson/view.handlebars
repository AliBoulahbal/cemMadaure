        border-color: var(--primary-light);
        box-shadow: var(--shadow-sm);
    }
    
    .info-label {
        font-size: 0.7rem;
        color: var(--gray-500);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
