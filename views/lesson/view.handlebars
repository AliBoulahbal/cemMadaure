        color: var(--gray-600);
        display: inline-block;
    }
    
    .badge-free {
        background: var(--success-light);
        color: var(--success);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }
    
    .badge-paid {
        background: var(--gray-100);
        color: var(--gray-500);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }
    
    .content-section {
        margin-top: 2rem;
        border-top: 1px solid var(--gray-200);
        padding-top: 1.5rem;
    }
    
    .section-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    
    .section-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--primary-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
    }
    
    .section-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0;
        flex: 1;
    }
    
    .modern-btn-sm {
        padding: 0.4rem 0.8rem;
        font-size: 0.75rem;
    }
    
    .modern-info-box {
        background: var(--info-light);
        border-radius: var(--radius-md);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        border-right: 3px solid var(--info);
        color: var(--info);
        font-size: 0.875rem;
    }
    
    .modern-info-box i {
        font-size: 1.25rem;
        margin-top: 0.125rem;
    }
    
    .modern-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
    }
    
    .modern-btn-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }
    
    .modern-btn-secondary:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }
    
    .modern-btn-warning {
        background: linear-gradient(135deg, var(--warning) 0%, #d97706 100%);
        color: white;
    }
    
    .modern-btn-warning:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .modern-btn-info {
        background: linear-gradient(135deg, var(--info) 0%, #2563eb 100%);
        color: white;
    }
    
    .modern-btn-info:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .modern-btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
    }
    
    .modern-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .text-muted { color: var(--gray-400); }
    
    @media (max-width: 768px) {
        .modern-card {
            margin: 1rem;
        }
        .modern-card-header,
        .modern-card-body {
            padding: 1rem;
        }
        .header-actions {
            width: 100%;
            justify-content: flex-start;
        }
        .modern-btn {
            padding: 0.4rem 0.8rem;
            font-size: 0.75rem;
        }
    }
</style>