<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-chart-line"></i> محاولات الاختبار: {{lesson.name}}
        </h3>
        <div class="card-tools">
            <a href="/quiz/lesson/{{lesson._id}}" class="btn btn-default btn-sm">
                <i class="fas fa-arrow-left"></i> رجوع
            </a>
        </div>
    </div>
    
    <div class="card-body">
        <!-- إحصائيات -->
        <div class="row mb-4">
            <div class="col-md-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>{{stats.total}}</h3>
                        <p>عدد المحاولات</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>{{stats.avgScore}}</h3>
                        <p>متوسط النقاط</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>{{stats.maxScore}}</h3>
                        <p>أعلى نتيجة</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>{{stats.uniqueStudents}}</h3>
                        <p>عدد الطلاب</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- جدول المحاولات -->
        <div class="table-responsive">
            <table class="table table-bordered table-hover datatable">
                <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>الطالب</th>
                        <th>النتيجة</th>
                        <th>التاريخ</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each attempts}}
                    <tr>
                        <td>{{inc @index}}</td>
                        <td>{{this.clientId.fullName}}</td>
                        <td>
                            <span class="badge badge-{{#if (gte this.score 70)}}success{{else if (gte this.score 50)}}warning{{else}}danger{{/if}}">
                                {{this.score}}
                            </span>
                        </td>
                        <td>{{formatDate this.createdAt}}</td>
                        <td>
                            <a href="/quiz-attempt/view/{{this._id}}" class="btn btn-info btn-sm">
                                <i class="fas fa-eye"></i> عرض
                            </a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="5" class="text-center">لا توجد محاولات لهذا الدرس</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>