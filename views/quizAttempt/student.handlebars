<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-user-graduate"></i> محاولات الطالب: {{student.fullName}}
        </h3>
        <div class="card-tools">
            <a href="/users" class="btn btn-default btn-sm">
                <i class="fas fa-arrow-left"></i> رجوع
            </a>
        </div>
    </div>
    
    <div class="card-body">
        <!-- معلومات الطالب -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="info-box bg-info">
                    <span class="info-box-icon"><i class="fas fa-envelope"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">البريد الإلكتروني</span>
                        <span class="info-box-number">{{student.email}}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-box bg-success">
                    <span class="info-box-icon"><i class="fas fa-phone"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">الهاتف</span>
                        <span class="info-box-number">{{student.phone}}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-box bg-warning">
                    <span class="info-box-icon"><i class="fas fa-calendar"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">تاريخ التسجيل</span>
                        <span class="info-box-number">{{formatDate student.createdAt}}</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- إحصائيات المحاولات -->
        <div class="row mb-4">
            <div class="col-md-4 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>{{stats.total}}</h3>
                        <p>عدد المحاولات</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>{{stats.avgScore}}</h3>
                        <p>متوسط النقاط</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>{{stats.bestScore}}</h3>
                        <p>أفضل نتيجة</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- جدول المحاولات -->
        <div class="table-responsive">
            <table class="table table-bordered table-hover datatable">
                <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>الدرس</th>
                        <th>النتيجة</th>
                        <th>التاريخ</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each attempts}}
                    <tr>
                        <td>{{inc @index}}</td>
                        <td>{{this.lessonId.name}}</td>
                        <td>
                            <span class="badge badge-{{#if (gte this.score 70)}}success{{else if (gte this.score 50)}}warning{{else}}danger{{/if}}">
                                {{this.score}}
                            </span>
                        </td>
                        <td>{{formatDate this.createdAt}}</td>
                        <td>
                            <a href="/quiz-attempt/view/{{this._id}}" class="btn btn-info btn-sm">
                                <i class="fas fa-eye"></i> عرض
                            </a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="5" class="text-center">لا توجد محاولات لهذا الطالب</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>