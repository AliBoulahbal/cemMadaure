<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-chart-line"></i> جميع محاولات الاختبارات
        </h3>
    </div>
    
    <div class="card-body">
        <!-- إحصائيات -->
        <div class="row mb-4">
            <div class="col-md-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>{{stats.total}}</h3>
                        <p>إجمالي المحاولات</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>{{stats.today}}</h3>
                        <p>اليوم</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>{{stats.thisWeek}}</h3>
                        <p>هذا الأسبوع</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>{{stats.avgScore}}</h3>
                        <p>متوسط النقاط</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- جدول المحاولات -->
        <div class="table-responsive">
            <table class="table table-bordered table-hover datatable">
                <thead class="thead-dark">
                    <tr>
                        <th>#</th>
                        <th>الطالب</th>
                        <th>الدرس</th>
                        <th>النتيجة</th>
                        <th>التاريخ</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each attempts}}
                    <tr>
                        <td>{{inc @index}}</td>
                        <td>
                            {{#if this.clientId}}
                                {{this.clientId.fullName}}
                                <br>
                                <small class="text-muted">{{this.clientId.email}}</small>
                            {{else}}
                                <span class="text-muted">مستخدم غير موجود</span>
                            {{/if}}
                        </td>
                        <td>{{this.lessonId.name}}</td>
                        <td>
                            <span class="badge badge-{{#if (gte this.score 70)}}success{{else if (gte this.score 50)}}warning{{else}}danger{{/if}}">
                                {{this.score}}
                            </span>
                         </td>
                        <td>{{formatDate this.createdAt}}</td>
                        <td>
                            <a href="/quiz-attempt/view/{{this._id}}" class="btn btn-info btn-sm">
                                <i class="fas fa-eye"></i> عرض
                            </a>
                            <form action="/quiz-attempt/delete/{{this._id}}?_method=DELETE" method="post" style="display: inline;">
                                <button type="submit" class="btn btn-danger btn-sm delete-btn">
                                    <i class="fas fa-trash"></i> حذف
                                </button>
                            </form>
                         </td>
                     </tr>
                    {{else}}
                    <tr>
                        <td colspan="6" class="text-center">لا توجد محاولات حتى الآن</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        {{#if pagination}}
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                {{#if pagination.hasPrev}}
                <li class="page-item">
                    <a class="page-link" href="?page={{pagination.prev}}">السابق</a>
                </li>
                {{/if}}
                
                <li class="page-item active">
                    <span class="page-link">{{pagination.current}} / {{pagination.total}}</span>
                </li>
                
                {{#if pagination.hasNext}}
                <li class="page-item">
                    <a class="page-link" href="?page={{pagination.next}}">التالي</a>
                </li>
                {{/if}}
            </ul>
        </nav>
        {{/if}}
    </div>
</div>