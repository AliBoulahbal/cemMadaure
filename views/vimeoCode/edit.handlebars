<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-semibold">
                <i class="fab fa-vimeo text-warning me-2"></i>Modifier le code Vimeo
            </h4>
            <p class="text-muted small mt-1">Code: <code>{{code.code}}</code></p>
        </div>
        <a href="/vimeo-code" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-right me-1"></i>Retour
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form action="/vimeo-code/update/{{code._id}}?_method=PUT" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="code" value="{{code.code}}" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">Utilisateur</label>
                        <input type="text" class="form-control" name="user" value="{{code.user}}">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">Statut</label>
                        <select class="form-select" name="status">
                            <option value="PENDING" {{#if (eq code.status 'PENDING')}}selected{{/if}}>En attente</option>
                            <option value="ACTIVE" {{#if (eq code.status 'ACTIVE')}}selected{{/if}}>Actif</option>
                            <option value="USED" {{#if (eq code.status 'USED')}}selected{{/if}}>Utilisé</option>
                            <option value="EXPIRED" {{#if (eq code.status 'EXPIRED')}}selected{{/if}}>Expiré</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">Date d'expiration</label>
                        <input type="datetime-local" class="form-control" name="expiresAt" value="{{#if code.expiresAt}}{{formatDateTimeLocal code.expiresAt}}{{/if}}">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold small">Titre de la vidéo</label>
                        <input type="text" class="form-control" name="videoTitle" value="{{code.videoTitle}}">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold small">URL de la vidéo</label>
                        <input type="text" class="form-control" name="videoUrl" value="{{code.videoUrl}}">
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold small">Description</label>
                        <textarea class="form-control" name="description" rows="3">{{code.description}}</textarea>
                    </div>
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fas fa-save me-1"></i>Mettre à jour
                        </button>
                        <a href="/vimeo-code" class="btn btn-light px-4">Annuler</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Helper pour formater la date en datetime-local
function formatDateTimeLocal(date) {
    if (!date) return '';
    const d = new Date(date);
    return d.toISOString().slice(0, 16);
}
</script>

<style>
.card {
    border-radius: 20px;
}
.form-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #64748b;
    margin-bottom: 0.35rem;
}
.form-control, .form-select {
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
}
.form-control:focus, .form-select:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
}
.btn-primary {
    background: #3b82f6;
    border: none;
    border-radius: 10px;
    padding: 0.5rem 1.2rem;
}
.btn-light {
    border-radius: 10px;
    border: 1px solid #e2e8f0;
}
code {
    background: #f1f5f9;
    padding: 0.2rem 0.5rem;
    border-radius: 8px;
    font-size: 0.85rem;
}
</style>