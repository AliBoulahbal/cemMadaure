<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-warning-light">
                <i class="fas fa-edit text-warning"></i>
            </div>
            <div>
                <h3 class="modern-title">تعديل الوحدة</h3>
                <p class="modern-subtitle">تعديل معلومات الوحدة: {{unit.name}}</p>
            </div>
        </div>
        <div class="header-actions">
            <a href="/unit" class="modern-btn modern-btn-secondary">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
            <button type="button" class="modern-btn modern-btn-danger" onclick="confirmDelete()">
                <i class="fas fa-trash"></i> حذف
            </button>
        </div>
    </div>
    
    <div class="modern-card-body">
        <form action="/unit/edit/{{unit._id}}?_method=PUT" method="post" id="editUnitForm" class="modern-form">
            <div class="form-grid">
                <div class="form-group-modern full-width">
                    <label for="name" class="form-label">
                        اسم الوحدة <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-tag input-icon"></i>
                        <input type="text" 
                               class="modern-input" 
                               id="name" 
                               name="name" 
                               value="{{unit.name}}" 
                               required>
                    </div>
                    <span class="form-hint">يمكنك تعديل اسم الوحدة إذا لزم الأمر</span>
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="branchId" class="form-label">
                        السنة الدراسية <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-graduation-cap input-icon"></i>
                        <select class="modern-input" id="branchId" name="branchId" required>
                            <option value="">-- اختر سنة --</option>
                            {{#each branches}}
                            <option value="{{this._id}}" {{#if (eq this._id ../unit.branchId)}}selected{{/if}}>
                                {{this.name}}
                            </option>
                            {{/each}}
                        </select>
                    </div>
                    <span class="form-hint">يمكنك تغيير السنة إذا لزم الأمر</span>
                </div>
                
                <div class="form-group-modern">
                    <label for="subjectId" class="form-label">
                        المادة <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-book input-icon"></i>
                        <select class="modern-input" id="subjectId" name="subjectId" required>
                            <option value="">-- اختر مادة --</option>
                            {{#each subjects}}
                            <option value="{{this._id}}" {{#if (eq this._id ../unit.subjectId)}}selected{{/if}}>
                                {{this.name}}
                            </option>
                            {{/each}}
                        </select>
                    </div>
                    <span class="form-hint">يمكنك تغيير المادة إذا لزم الأمر</span>
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="order" class="form-label">ترتيب العرض</label>
                    <div class="input-wrapper">
                        <i class="fas fa-sort-numeric-down input-icon"></i>
                        <input type="number" 
                               class="modern-input" 
                               id="order" 
                               name="order" 
                               value="{{unit.order}}"
                               min="0"
                               placeholder="0">
                    </div>
                    <span class="form-hint">تعديل ترتيب ظهور الوحدة</span>
                </div>
                
                <div class="form-group-modern">
                    <label for="description" class="form-label">الوصف</label>
                    <div class="input-wrapper">
                        <i class="fas fa-align-right input-icon textarea-icon"></i>
                        <textarea class="modern-input modern-textarea" 
                                  id="description" 
                                  name="description" 
                                  rows="3">{{unit.description}}</textarea>
                    </div>
                </div>
            </div>
            
            <div class="modern-warning-box">
                <i class="fas fa-exclamation-triangle"></i>
                <div>
                    <strong>تنبيه:</strong> تعديل هذه الوحدة قد يؤثر على ترتيب الدروس المرتبطة بها.
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="modern-btn modern-btn-primary">
                    <i class="fas fa-save"></i> تحديث
                </button>
                <a href="/unit" class="modern-btn modern-btn-secondary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

<form action="/unit/delete/{{unit._id}}?_method=DELETE" method="post" id="deleteForm" style="display: none;"></form>

<style>
    * {
        direction: rtl;
        text-align: right;
    }
    
