<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-warning-light">
                <i class="fas fa-clock text-warning"></i>
            </div>
            <div>
                <h3 class="modern-title">الوحدات قيد المراجعة</h3>
                <p class="modern-subtitle">مراجعة الوحدات المنتظرة للنشر</p>
            </div>
        </div>
        <a href="/unit" class="modern-btn modern-btn-secondary">
            <i class="fas fa-arrow-right"></i> رجوع
        </a>
    </div>
    
    <div class="modern-card-body">
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon bg-warning-light">
                    <i class="fas fa-hourglass-half text-warning"></i>
                </div>
                <div class="stat-value">{{stats.pending}}</div>
                <div class="stat-label">قيد المراجعة</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-info-light">
                    <i class="fas fa-layer-group text-info"></i>
                </div>
                <div class="stat-value">{{stats.total}}</div>
                <div class="stat-label">إجمالي الوحدات</div>
            </div>
        </div>
        
        {{#if units.length}}
        <div class="table-wrapper">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>الوحدة</th>
                        <th>المادة</th>
                        <th>السنة</th>
                        <th>المنشئ</th>
                        <th>تاريخ الإنشاء</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each units}}
                    <tr id="row-{{this._id}}">
                        <td>
                            <div class="unit-info">
                                <div class="unit-icon pending-icon">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="unit-details">
                                    <strong>{{this.name}}</strong>
                                    <span class="badge-modern badge-pending">قيد المراجعة</span>
                                </div>
                            </div>
                        </tr>
                        <td>{{this.subjectId.name}}</td>
                        <td>{{this.branchId.name}}</td>
                        <td>
                            <div class="creator-info">
                                <i class="fas fa-user-circle"></i>
                                <div>
                                    <div class="creator-name">{{this.createdBy.fullName}}</div>
                                    <div class="creator-username">{{this.createdBy.username}}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="date-info">
                                <i class="fas fa-calendar-alt"></i>
                                <span>{{formatDate this.createdAt}}</span>
                            </div>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <button class="action-btn action-approve" data-id="{{this._id}}" data-name="{{this.name}}">
                                    <i class="fas fa-check-circle"></i>
                                    <span>موافقة</span>
                                </button>
                                <button class="action-btn action-reject" data-id="{{this._id}}" data-name="{{this.name}}">
                                    <i class="fas fa-times-circle"></i>
                                    <span>رفض</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h4>لا توجد وحدات في انتظار المراجعة</h4>
            <p class="empty-description">جميع الوحدات قد تمت مراجعتها ونشرها</p>
        </div>
        {{/if}}
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" style="display: none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-times-circle"></i> رفض الوحدة</h5>
                <button type="button" class="modal-close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="rejectUnitId">
                <div class="form-group-modern">
                    <label class="form-label">سبب الرفض</label>
                    <textarea id="rejectionReason" class="modern-input" rows="3" placeholder="اكتب سبب الرفض..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="modern-btn modern-btn-secondary" data-dismiss="modal">إلغاء</button>
                <button type="button" id="confirmReject" class="modern-btn modern-btn-danger">تأكيد الرفض</button>
            </div>
        </div>
    </div>
</div>

<style>
    * {
        direction: rtl;
        text-align: right;
    }
    
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #eef2ff;
        --success: #10b981;
        --success-light: #d1fae5;
        --warning: #f59e0b;
        --warning-light: #fef3c7;
        --danger: #ef4444;
        --danger-light: #fee2e2;
        --info: #3b82f6;
        --info-light: #dbeafe;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.5rem;
        --radius-lg: 0.75rem;
        --radius-xl: 1rem;
    }
    
    .modern-card {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin: 1.5rem;
    }
    
    .modern-card-header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .modern-title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .modern-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-warning-light { background: var(--warning-light); }
    .text-warning { color: var(--warning); }
    
    .modern-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }
    
    .modern-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
        margin: 0;
    }
    
    .modern-card-body {
        padding: 2rem;
    }
    
    .stats-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    
    .stat-card {
        flex: 1;
        min-width: 150px;
        background: white;
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        text-align: center;
        border: 1px solid var(--gray-200);
        box-shadow: var(--shadow-sm);
        transition: all 0.2s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }
    
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.75rem;
        font-size: 1.25rem;
    }
    
    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--gray-800);
    }
    
    .stat-label {
        font-size: 0.75rem;
        color: var(--gray-500);
        margin-top: 0.25rem;
    }
    
    .table-wrapper {
        overflow-x: auto;
        border-radius: var(--radius-lg);
        border: 1px solid var(--gray-200);
    }
    
    .modern-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }
    
    .modern-table thead {
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
    }
    
    .modern-table th {
        padding: 1rem 1.25rem;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.8125rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .modern-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--gray-100);
        color: var(--gray-700);
        vertical-align: middle;
    }
    
    .modern-table tbody tr:hover {
        background: var(--gray-50);
    }
    
    .unit-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .unit-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--warning-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--warning);
    }
    
    .unit-details {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .badge-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 500;
        width: fit-content;
    }
    
    .badge-pending {
        background: var(--warning-light);
        color: var(--warning);
    }
    
    .creator-info, .date-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .creator-name {
        font-weight: 500;
        color: var(--gray-700);
    }
    
    .creator-username {
        font-size: 0.7rem;
        color: var(--gray-400);
    }
    
    .date-info {
        color: var(--gray-500);
        font-size: 0.75rem;
    }
    
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-md);
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        text-decoration: none;
    }
    
    .action-approve {
        background: var(--success-light);
        color: var(--success);
    }
    
    .action-approve:hover {
        background: var(--success);
        color: white;
    }
    
    .action-reject {
        background: var(--danger-light);
        color: var(--danger);
    }
    
    .action-reject:hover {
        background: var(--danger);
        color: white;
    }
    
    .modern-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
    }
    
    .modern-btn-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }
    
    .modern-btn-secondary:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }
    
    .modern-btn-danger {
        background: linear-gradient(135deg, var(--danger) 0%, #dc2626 100%);
        color: white;
    }
    
    .modern-btn-danger:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
    }
    
    .empty-icon {
        font-size: 3rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
    }
    
    .empty-state h4 {
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--gray-600);
        margin-bottom: 0.5rem;
    }
    
    .empty-description {
        color: var(--gray-400);
        font-size: 0.875rem;
    }
    
    /* Modal Styles */
    .modal {
        position: fixed;
        top: 0;
        right: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    
    .modal-dialog {
        width: 500px;
        max-width: 90%;
    }
    
    .modal-content {
        background: white;
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }
    
    .modal-header {
        padding: 1rem 1.5rem;
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .modal-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0;
    }
    
    .modal-close {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--gray-400);
    }
    
    .modal-body {
        padding: 1.5rem;
    }
    
    .modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--gray-200);
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
    }
    
    .form-group-modern {
        margin-bottom: 0;
    }
    
    .form-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--gray-700);
        margin-bottom: 0.5rem;
    }
    
    .modern-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid var(--gray-200);
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        color: var(--gray-700);
        background: white;
        transition: all 0.2s ease;
    }
    
    .modern-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-light);
    }
    
    @media (max-width: 768px) {
        .modern-card {
            margin: 1rem;
        }
        .modern-card-header,
        .modern-card-body {
            padding: 1rem;
        }
        .stats-row {
            flex-direction: column;
        }
        .action-btn span {
            display: none;
        }
        .action-btn {
            padding: 0.5rem;
        }
        .modern-table th,
        .modern-table td {
            padding: 0.75rem;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<script>
// Approbation
document.querySelectorAll('.action-approve').forEach(btn => {
    btn.addEventListener('click', async function() {
        const unitId = this.dataset.id;
        const unitName = this.dataset.name;
        
        const result = await Swal.fire({
            title: 'تأكيد الموافقة',
            text: `هل أنت متأكد من الموافقة على نشر "${unitName}"؟`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'نعم، وافق',
            cancelButtonText: 'إلغاء'
        });
        
        if (result.isConfirmed) {
            try {
                const response = await fetch(`/unit/approve/${unitId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire('تم!', 'تم نشر الوحدة بنجاح', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    Swal.fire('خطأ', data.error, 'error');
                }
            } catch (error) {
                Swal.fire('خطأ', error.message, 'error');
            }
        }
    });
});

// Rejet
let currentRejectId = null;

document.querySelectorAll('.action-reject').forEach(btn => {
    btn.addEventListener('click', function() {
        currentRejectId = this.dataset.id;
        document.getElementById('rejectUnitId').value = this.dataset.id;
        document.getElementById('rejectionReason').value = '';
        $('#rejectModal').modal('show');
    });
});

document.getElementById('confirmReject')?.addEventListener('click', async function() {
    const unitId = currentRejectId;
    const reason = document.getElementById('rejectionReason').value;
    
    if (!reason) {
        Swal.fire('خطأ', 'الرجاء إدخال سبب الرفض', 'error');
        return;
    }
    
    try {
        const response = await fetch(`/unit/reject/${unitId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rejectionReason: reason })
        });
        const data = await response.json();
        
        if (data.success) {
            Swal.fire('تم!', 'تم رفض الوحدة', 'success');
            $('#rejectModal').modal('hide');
            setTimeout(() => location.reload(), 1500);
        } else {
            Swal.fire('خطأ', data.error, 'error');
        }
    } catch (error) {
        Swal.fire('خطأ', error.message, 'error');
    }
});
</script>