<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-primary-light">
                <i class="fas fa-layer-group text-primary"></i>
            </div>
            <div>
                <h3 class="modern-title">إضافة وحدة جديدة</h3>
                <p class="modern-subtitle">قم بإضافة وحدة تعليمية جديدة للمادة</p>
            </div>
        </div>
        <a href="/unit" class="modern-btn modern-btn-secondary">
            <i class="fas fa-arrow-right"></i> رجوع
        </a>
    </div>
    
    <div class="modern-card-body">
        {{#if error}}
        <div class="modern-alert modern-alert-danger">
            <i class="fas fa-exclamation-circle"></i> {{error}}
        </div>
        {{/if}}
        
        {{#if success}}
        <div class="modern-alert modern-alert-success">
            <i class="fas fa-check-circle"></i> {{success}}
        </div>
        {{/if}}
        
        <form action="/unit/create" method="post" id="createUnitForm" class="modern-form">
            <div class="modern-info-box">
                <i class="fas fa-info-circle"></i>
                <div>
                    <strong>معلومات:</strong> الوحدة هي مجموعة من الدروس (مثال: "الفصل الأول"، "الوحدة الأولى"، إلخ.)
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern full-width">
                    <label for="name" class="form-label">
                        اسم الوحدة <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-tag input-icon"></i>
                        <input type="text" 
                               class="modern-input" 
                               id="name" 
                               name="name" 
                               placeholder="مثال: الفصل الأول: الأعداد، الوحدة الأولى: القواعد..." 
                               value="{{formData.name}}"
                               required
                               autofocus>
                    </div>
                    <span class="form-hint">أدخل الاسم الكامل للوحدة التعليمية</span>
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="branchId" class="form-label">
                        السنة الدراسية <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-graduation-cap input-icon"></i>
                        <select class="modern-input" id="branchId" name="branchId" required>
                            <option value="">-- اختر سنة --</option>
                            {{#each branches}}
                            <option value="{{this._id}}" {{#if (eq this._id ../formData.branchId)}}selected{{/if}}>
                                {{this.name}}
                            </option>
                            {{/each}}
                        </select>
                    </div>
                    <span class="form-hint">اختر السنة التي تتبعها هذه الوحدة</span>
                    
                    {{#if (lt branches.length 1)}}
                    <div class="modern-warning-box mt-2">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>لا توجد سنوات دراسية متاحة. <a href="/branch">أضف سنة أولاً</a></span>
                    </div>
                    {{/if}}
                </div>
                
                <div class="form-group-modern">
                    <label for="subjectId" class="form-label">
                        المادة <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-book input-icon"></i>
                        <select class="modern-input" id="subjectId" name="subjectId" required>
                            <option value="">-- اختر مادة --</option>
                            {{#each subjects}}
                            <option value="{{this._id}}" {{#if (eq this._id ../formData.subjectId)}}selected{{/if}}>
                                {{this.name}}
                            </option>
                            {{/each}}
                        </select>
                    </div>
                    <span class="form-hint">اختر المادة التي تتبعها هذه الوحدة</span>
                </div>
            </div>
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="order" class="form-label">ترتيب العرض</label>
                    <div class="input-wrapper">
                        <i class="fas fa-sort-numeric-down input-icon"></i>
                        <input type="number" 
                               class="modern-input" 
                               id="order" 
                               name="order" 
                               value="{{nextOrder}}" 
                               min="0"
                               placeholder="0">
                    </div>
                    <span class="form-hint">كلما كان الرقم أصغر، كلما ظهرت الوحدة أولاً</span>
                </div>
                
                <div class="form-group-modern">
                    <label for="description" class="form-label">الوصف</label>
                    <div class="input-wrapper">
                        <i class="fas fa-align-right input-icon textarea-icon"></i>
                        <textarea class="modern-input modern-textarea" 
                                  id="description" 
                                  name="description" 
                                  rows="3" 
                                  placeholder="وصف الوحدة...">{{formData.description}}</textarea>
                    </div>
                    <span class="form-hint">أضف وصفاً لتوضيح محتوى الوحدة (اختياري)</span>
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="modern-btn modern-btn-primary">
                    <i class="fas fa-save"></i> حفظ الوحدة
                </button>
                <button type="reset" class="modern-btn modern-btn-secondary">
                    <i class="fas fa-undo"></i> إعادة تعيين
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    * {
        direction: rtl;
        text-align: right;
    }
    
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #eef2ff;
        --success: #10b981;
        --success-light: #d1fae5;
        --warning: #f59e0b;
        --warning-light: #fef3c7;
        --danger: #ef4444;
        --danger-light: #fee2e2;
        --info: #3b82f6;
        --info-light: #dbeafe;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.5rem;
        --radius-lg: 0.75rem;
        --radius-xl: 1rem;
    }
    
    .modern-card {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin: 1.5rem;
    }
    
    .modern-card-header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .modern-title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .modern-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-primary-light { background: var(--primary-light); }
    .bg-warning-light { background: var(--warning-light); }
    .bg-success-light { background: var(--success-light); }
    
    .modern-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }
    
    .modern-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
        margin: 0;
    }
    
    .modern-card-body {
        padding: 2rem;
    }
    
    .modern-form {
        max-width: 100%;
    }
    
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    
    .full-width {
        grid-column: span 2;
    }
    
    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
        .full-width {
            grid-column: span 1;
        }
        .modern-card {
            margin: 1rem;
        }
        .modern-card-header,
        .modern-card-body {
            padding: 1rem;
        }
    }
    
    .form-group-modern {
        margin-bottom: 0;
    }
    
    .form-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--gray-700);
        margin-bottom: 0.5rem;
    }
    
    .required {
        color: var(--danger);
    }
    
    .input-wrapper {
        position: relative;
    }
    
    .input-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: 1rem;
        pointer-events: none;
    }
    
    .textarea-icon {
        top: 1rem;
        transform: none;
    }
    
    .modern-input {
        width: 100%;
        padding: 0.75rem 2.5rem 0.75rem 1rem;
        border: 1.5px solid var(--gray-200);
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        color: var(--gray-700);
        background: white;
        transition: all 0.2s ease;
    }
    
    .modern-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-light);
    }
    
    .modern-textarea {
        padding: 1rem 2.5rem 1rem 1rem;
        resize: vertical;
    }
    
    .form-hint {
        display: block;
        font-size: 0.75rem;
        color: var(--gray-400);
        margin-top: 0.375rem;
    }
    
    .modern-alert {
        padding: 1rem 1.25rem;
        border-radius: var(--radius-md);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
    }
    
    .modern-alert-danger {
        background: var(--danger-light);
        color: var(--danger);
        border-right: 3px solid var(--danger);
    }
    
    .modern-alert-success {
        background: var(--success-light);
        color: var(--success);
        border-right: 3px solid var(--success);
    }
    
    .modern-info-box {
        background: var(--info-light);
        border-radius: var(--radius-md);
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        border-right: 3px solid var(--info);
        color: var(--info);
        font-size: 0.875rem;
    }
    
    .modern-info-box i {
        font-size: 1.25rem;
        margin-top: 0.125rem;
    }
    
    .modern-warning-box {
        background: var(--warning-light);
        border-radius: var(--radius-md);
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        color: var(--warning);
        border-right: 3px solid var(--warning);
    }
    
    .modern-warning-box a {
        color: var(--warning);
        font-weight: 500;
    }
    
    .modern-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
    }
    
    .modern-btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        box-shadow: var(--shadow-sm);
    }
    
    .modern-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .modern-btn-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }
    
    .modern-btn-secondary:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }
    
    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--gray-200);
    }
    
    .text-primary { color: var(--primary); }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('createUnitForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            const name = document.getElementById('name').value.trim();
            const branchId = document.getElementById('branchId').value;
            const subjectId = document.getElementById('subjectId').value;
            
            if (!name) {
                e.preventDefault();
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'الرجاء إدخال اسم الوحدة' });
                return false;
            }
            
            if (!branchId) {
                e.preventDefault();
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'الرجاء اختيار السنة الدراسية' });
                return false;
            }
            
            if (!subjectId) {
                e.preventDefault();
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'الرجاء اختيار المادة' });
                return false;
            }
        });
    }
});
</script>