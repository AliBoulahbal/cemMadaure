<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-info-light">
                <i class="fas fa-layer-group text-info"></i>
            </div>
            <div>
                <h3 class="modern-title">{{unit.name}}</h3>
                <p class="modern-subtitle">عرض تفاصيل الوحدة والدروس المرتبطة بها</p>
            </div>
        </div>
        <div class="header-actions">
            <a href="/unit" class="modern-btn modern-btn-secondary">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
            <a href="/unit/edit/{{unit._id}}" class="modern-btn modern-btn-warning">
                <i class="fas fa-edit"></i> تعديل
            </a>
        </div>
    </div>
    
    <div class="modern-card-body">
        <div class="info-grid">
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-tag"></i> اسم الوحدة
                </div>
                <div class="info-value">{{unit.name}}</div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-graduation-cap"></i> السنة الدراسية
                </div>
                <div class="info-value">
                    {{#if unit.branchId}}
                        {{#if unit.branchId.name}}
                            <span class="badge-modern badge-branch">{{unit.branchId.name}}</span>
                        {{else}}
                            <span class="text-muted">غير محدد</span>
                        {{/if}}
                    {{else}}
                        <span class="text-muted">غير محدد</span>
                    {{/if}}
                </div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-book"></i> المادة
                </div>
                <div class="info-value">
                    {{#if unit.subjectId}}
                        {{#if unit.subjectId.name}}
                            <span class="badge-modern badge-subject">{{unit.subjectId.name}}</span>
                        {{else}}
                            <span class="text-muted">غير محدد</span>
                        {{/if}}
                    {{else}}
                        <span class="text-muted">غير محدد</span>
                    {{/if}}
                </div>
            </div>
            
            <div class="info-card">
                <div class="info-label">
                    <i class="fas fa-sort-numeric-down"></i> الترتيب
                </div>
                <div class="info-value">
                    <span class="order-badge">{{unit.order}}</span>
                </div>
            </div>
            
            <div class="info-card full-width">
                <div class="info-label">
                    <i class="fas fa-align-right"></i> الوصف
                </div>
                <div class="info-value">
                    {{#if unit.description}}
                        {{unit.description}}
                    {{else}}
                        <span class="text-muted">لا يوجد وصف</span>
                    {{/if}}
                </div>
            </div>
        </div>
        
        <div class="lessons-section">
            <div class="section-header">
                <div class="section-icon">
                    <i class="fas fa-video"></i>
                </div>
                <h4 class="section-title">الدروس في هذه الوحدة</h4>
                <span class="lessons-count">{{lessons.length}} دروس</span>
            </div>
            
            <div class="table-wrapper">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th class="col-number">#</th>
                            <th>اسم الدرس</th>
                            <th>المادة</th>
                            <th>الترتيب</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each lessons}}
                        <tr>
                            <td class="text-center">{{inc @index}}</td>
                            <td>
                                <div class="lesson-info">
                                    <i class="fas fa-play-circle"></i>
                                    <strong>{{this.name}}</strong>
                                </div>
                            </td>
                            <td>
                                <span class="badge-modern badge-subject small">{{this.subjectId.name}}</span>
                            </td>
                            <td>
                                <span class="order-badge small">{{this.order}}</span>
                            </td>
                            <td>
                                <a href="/lesson/view/{{this._id}}" class="action-btn action-view">
                                    <i class="fas fa-eye"></i>
                                    <span>عرض</span>
                                </a>
                            </td>
                        </tr>
                        {{else}}
                        <tr>
                            <td colspan="5">
                                <div class="empty-state-small">
                                    <i class="fas fa-info-circle"></i>
                                    <p>لا توجد دروس في هذه الوحدة</p>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
