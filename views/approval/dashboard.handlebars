<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-check-double"></i> لوحة المراجعة
        </h3>
        <div class="card-tools">
            <span class="badge bg-warning">قيد المراجعة</span>
        </div>
    </div>
    
    <div class="card-body">
        <!-- Statistiques -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon bg-unit"><i class="fas fa-layer-group"></i></div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.pendingUnits}}</div>
                    <div class="stat-label">وحدات</div>
                </div>
                <a href="/unit/pending" class="stat-link">مراجعة <i class="fas fa-arrow-left"></i></a>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon bg-lesson"><i class="fas fa-chalkboard"></i></div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.pendingLessons}}</div>
                    <div class="stat-label">دروس</div>
                </div>
                <a href="/lesson/pending" class="stat-link">مراجعة <i class="fas fa-arrow-left"></i></a>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon bg-subject"><i class="fas fa-book"></i></div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.pendingSubjects}}</div>
                    <div class="stat-label">مواد</div>
                </div>
                <a href="/subject/pending" class="stat-link">مراجعة <i class="fas fa-arrow-left"></i></a>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon bg-content"><i class="fas fa-file-alt"></i></div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.pendingContents}}</div>
                    <div class="stat-label">محتوى</div>
                </div>
                <a href="/approval/pending" class="stat-link">مراجعة <i class="fas fa-arrow-left"></i></a>
            </div>
        </div>
        
        <!-- Liste des éléments récents -->
        <div class="recent-section">
            <h4><i class="fas fa-history"></i> آخر العناصر قيد المراجعة</h4>
            
            {{#if pendingItems.length}}
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>النوع</th>
                            <th>العنوان</th>
                            <th>المنشئ</th>
                            <th>التاريخ</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each pendingItems}}
                        <tr>
                            <td>
                                {{#if (eq this.type 'unit')}}
                                    <span class="type-badge type-unit"><i class="fas fa-layer-group"></i> وحدة</span>
                                {{else if (eq this.type 'lesson')}}
                                    <span class="type-badge type-lesson"><i class="fas fa-chalkboard"></i> درس</span>
                                {{else if (eq this.type 'subject')}}
                                    <span class="type-badge type-subject"><i class="fas fa-book"></i> مادة</span>
                                {{else}}
                                    <span class="type-badge type-content"><i class="fas fa-file-alt"></i> محتوى</span>
                                {{/if}}
                            </td>
                            <td><strong>{{this.name}}{{this.title}}</strong></td>
                            <td>
                                {{this.createdBy.fullName}}<br>
                                <small>{{this.createdBy.username}}</small>
                            </td>
                            <td>{{formatDate this.createdAt}}</td>
                            <td>
                                <button onclick="approveItem('{{this.type}}', '{{this._id}}', 'PUBLISHED')" class="btn-approve" title="نشر">
                                    <i class="fas fa-check-circle"></i>
                                </button>
                                <button onclick="rejectItem('{{this.type}}', '{{this._id}}')" class="btn-reject" title="رفض">
                                    <i class="fas fa-times-circle"></i>
                                </button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <div class="empty-state">
                <i class="fas fa-check-circle fa-3x"></i>
                <p>لا توجد عناصر في انتظار المراجعة</p>
            </div>
            {{/if}}
        </div>
    </div>
</div>

<style>
.stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid #eef2f6;
    position: relative;
}

.stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: white;
}

.bg-unit { background: #3b82f6; }
.bg-lesson { background: #10b981; }
.bg-subject { background: #f59e0b; }
.bg-content { background: #8b5cf6; }

.stat-info {
    flex: 1;
}

.stat-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1e293b;
}

.stat-label {
    font-size: 0.7rem;
    color: #64748b;
}

.stat-link {
    position: absolute;
    bottom: 10px;
    left: 15px;
    font-size: 0.7rem;
    color: #3b82f6;
    text-decoration: none;
}

.recent-section h4 {
    font-size: 1rem;
    margin-bottom: 1rem;
}

.type-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.65rem;
    font-weight: 500;
}

.type-unit { background: #eff6ff; color: #3b82f6; }
.type-lesson { background: #ecfdf5; color: #10b981; }
.type-subject { background: #fffbeb; color: #f59e0b; }
.type-content { background: #f5f3ff; color: #8b5cf6; }

.btn-view, .btn-approve {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
}

.btn-view { color: #3b82f6; }
.btn-view:hover { background: #eff6ff; }
.btn-approve { color: #10b981; }
.btn-approve:hover { background: #ecfdf5; }
.btn-reject { color: #ef4444; display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: none; border: none; cursor: pointer; }
.btn-reject:hover { background: #fef2f2; }

.empty-state {
    text-align: center;
    padding: 3rem;
    color: #94a3b8;
}
</style>

<script>
const APPROVAL_URLS = {
    content: (id) => `/approval/content/${id}`,
    subject: (id) => `/approval/subject/${id}`,
    lesson:  (id) => `/approval/lesson/${id}`,
    unit:    (id) => `/approval/unit/${id}`,
};

async function approveItem(type, id, status) {
    const url = APPROVAL_URLS[type]?.(id);
    if (!url) return Swal.fire('خطأ', 'نوع غير معروف', 'error');

    const confirm = await Swal.fire({
        title: 'تأكيد النشر',
        text: 'هل تريد نشر هذا العنصر؟',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'نعم، انشر',
        cancelButtonText: 'إلغاء',
        confirmButtonColor: '#10b981',
    });
    if (!confirm.isConfirmed) return;

    try {
        const res = await fetch(url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status, rejectionReason: '' })
        });
        const result = await res.json();
        if (result.success) {
            Swal.fire('✅', result.message, 'success').then(() => location.reload());
        } else {
            Swal.fire('خطأ', result.error, 'error');
        }
    } catch (err) {
        Swal.fire('خطأ', 'حدث خطأ في الاتصال', 'error');
    }
}

async function rejectItem(type, id) {
    const url = APPROVAL_URLS[type]?.(id);
    if (!url) return Swal.fire('خطأ', 'نوع غير معروف', 'error');

    const { value: reason, isConfirmed } = await Swal.fire({
        title: 'سبب الرفض',
        input: 'textarea',
        inputPlaceholder: 'اكتب سبب الرفض هنا...',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'رفض',
        cancelButtonText: 'إلغاء',
        confirmButtonColor: '#ef4444',
    });
    if (!isConfirmed) return;

    try {
        const res = await fetch(url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'REJECTED', rejectionReason: reason || '' })
        });
        const result = await res.json();
        if (result.success) {
            Swal.fire('✅', result.message, 'success').then(() => location.reload());
        } else {
            Swal.fire('خطأ', result.error, 'error');
        }
    } catch (err) {
        Swal.fire('خطأ', 'حدث خطأ في الاتصال', 'error');
    }
}
</script>