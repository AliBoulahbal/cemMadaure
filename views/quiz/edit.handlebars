<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-warning-light">
                <i class="fas fa-edit text-warning"></i>
            </div>
            <div>
                <h3 class="modern-title">تعديل الاختبار</h3>
                <p class="modern-subtitle">تعديل السؤال والخيارات</p>
            </div>
        </div>
        <div class="header-actions">
            <a href="/quiz/lesson/{{quiz.lessonId}}" class="modern-btn modern-btn-secondary">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
            <button type="button" class="modern-btn modern-btn-danger" onclick="confirmDelete()">
                <i class="fas fa-trash"></i> حذف
            </button>
        </div>
    </div>
    
    <div class="modern-card-body">
        <form action="/quiz/update/{{quiz._id}}?_method=PUT" method="post" id="quizForm" class="modern-form">
            <input type="hidden" name="lessonId" value="{{quiz.lessonId}}">
            <input type="hidden" name="options" id="optionsData">
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="order" class="form-label">الترتيب</label>
                    <div class="input-wrapper">
                        <i class="fas fa-sort-numeric-down input-icon"></i>
                        <input type="number" class="modern-input" id="order" name="order" value="{{quiz.order}}" min="0">
                    </div>
                </div>
                <div class="form-group-modern">
                    <label for="point" class="form-label">النقاط</label>
                    <div class="input-wrapper">
                        <i class="fas fa-star input-icon"></i>
                        <input type="number" class="modern-input" id="point" name="point" value="{{quiz.point}}" min="1">
                    </div>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="typeQuiz" class="form-label">نوع الاختبار <span class="required">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-list-ul input-icon"></i>
                    <select class="modern-input" id="typeQuiz" name="typeQuiz" required>
                        <option value="SINGLESELECT" {{#if (eq quiz.typeQuiz 'SINGLESELECT')}}selected{{/if}}>اختيار من متعدد (إجابة واحدة)</option>
                        <option value="MULTISELECT" {{#if (eq quiz.typeQuiz 'MULTISELECT')}}selected{{/if}}>اختيار من متعدد (إجابات متعددة)</option>
                    </select>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="question" class="form-label">السؤال <span class="required">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-question-circle input-icon"></i>
                    <input type="text" class="modern-input" id="question" name="question" value="{{quiz.question}}" required>
                </div>
            </div>

            <!-- ميديا السؤال الحالية + رفع جديد -->
            <div class="form-group-modern full-width">
                <label class="form-label">ميديا السؤال (صورة/فيديو/صوت)</label>
                <input type="hidden" name="subQuestion" id="subQuestion" value="{{quiz.subQuestion}}">
                <input type="hidden" name="questionMediaType" id="questionMediaType" value="{{quiz.questionMediaType}}">
                <input type="hidden" name="questionMediaUrl" id="questionMediaUrl" value="{{quiz.questionMediaUrl}}">

                <!-- Aperçu du média existant -->
                <div id="questionMediaPreview" class="media-preview-container">
                    {{#if quiz.questionMediaUrl}}
                    <div class="media-preview existing-media">
                        {{#if (eq quiz.questionMediaType 'image')}}
                            <img src="/v1/proxy?url={{quiz.questionMediaUrl}}" alt="Question media">
                        {{else if (eq quiz.questionMediaType 'video')}}
                            <video src="/v1/proxy?url={{quiz.questionMediaUrl}}" controls></video>
                        {{else if (eq quiz.questionMediaType 'audio')}}
                            <audio src="/v1/proxy?url={{quiz.questionMediaUrl}}" controls></audio>
                        {{/if}}
                        <span class="wasabi-badge"><i class="fas fa-cloud"></i> Wasabi</span>
                        <button type="button" class="modern-btn modern-btn-danger" onclick="removeQuestionMedia()">
                            <i class="fas fa-trash"></i> حذف الميديا
                        </button>
                    </div>
                    {{/if}}
                </div>

                <div class="media-buttons" style="margin-top:0.75rem;">
                    <button type="button" class="media-btn media-btn-image" onclick="uploadQuestionMedia('image')">
                        <i class="fas fa-image"></i> {{#if quiz.questionMediaUrl}}تغيير الصورة{{else}}إضافة صورة{{/if}}
                    </button>
                    <button type="button" class="media-btn media-btn-video" onclick="uploadQuestionMedia('video')">
                        <i class="fas fa-video"></i> {{#if quiz.questionMediaUrl}}تغيير الفيديو{{else}}إضافة فيديو{{/if}}
                    </button>
                    <button type="button" class="media-btn media-btn-audio" onclick="uploadQuestionMedia('audio')">
                        <i class="fas fa-headphones"></i> {{#if quiz.questionMediaUrl}}تغيير الصوت{{else}}إضافة صوت{{/if}}
                    </button>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="explanation" class="form-label">شرح الإجابة</label>
                <div class="input-wrapper">
                    <i class="fas fa-align-right input-icon textarea-icon"></i>
                    <textarea class="modern-input modern-textarea" id="explanation" name="explanation" rows="3">{{quiz.explanation}}</textarea>
                </div>
            </div>
            
            <!-- الخيارات -->
            <div class="form-group-modern full-width">
                <label class="form-label">الخيارات <span class="required">*</span></label>
                <div id="optionsContainer" class="options-container">
                    {{#each quiz.options}}
                    <div class="option-item" id="option-{{@index}}" data-option-id="{{this._id}}">
                        <div class="option-header">
                            <span class="option-number">الخيار {{inc @index}}</span>
                            <button type="button" class="modern-btn modern-btn-danger" style="padding: 0.25rem 0.75rem;" onclick="removeOption({{@index}})">
                                <i class="fas fa-trash"></i> حذف
                            </button>
                        </div>
                        <div class="option-content">
                            <div class="input-wrapper">
                                <i class="fas fa-font input-icon"></i>
                                <input type="text" class="modern-input" id="option-text-{{@index}}" value="{{this.content}}" required>
                            </div>
                        </div>

                        <!-- Média existant de l'option -->
                        <div class="option-media-section">
                            <label style="font-size:0.8rem;color:var(--gray-500);margin-bottom:0.4rem;display:block;">ميديا الخيار (اختياري)</label>
                            <div id="option-media-preview-{{@index}}" class="media-preview-container">
                                {{#if this.mediaUrl}}
                                <div class="media-preview existing-media">
                                    {{#if (eq this.mediaType 'image')}}
                                        <img src="/v1/proxy?url={{this.mediaUrl}}" alt="Option media">
                                    {{else if (eq this.mediaType 'video')}}
                                        <video src="/v1/proxy?url={{this.mediaUrl}}" controls></video>
                                    {{else if (eq this.mediaType 'audio')}}
                                        <audio src="/v1/proxy?url={{this.mediaUrl}}" controls></audio>
                                    {{/if}}
                                    <span class="wasabi-badge"><i class="fas fa-cloud"></i> Wasabi</span>
                                    <button type="button" class="modern-btn modern-btn-danger" onclick="removeOptionMedia({{@index}})">
                                        <i class="fas fa-trash"></i> حذف
                                    </button>
                                </div>
                                {{/if}}
                            </div>
                            <div class="media-buttons" style="margin-top:0.5rem;">
                                <button type="button" class="media-btn media-btn-image" onclick="uploadOptionMedia({{@index}}, 'image')">
                                    <i class="fas fa-image"></i> صورة
                                </button>
                                <button type="button" class="media-btn media-btn-video" onclick="uploadOptionMedia({{@index}}, 'video')">
                                    <i class="fas fa-video"></i> فيديو
                                </button>
                                <button type="button" class="media-btn media-btn-audio" onclick="uploadOptionMedia({{@index}}, 'audio')">
                                    <i class="fas fa-headphones"></i> صوت
                                </button>
                            </div>
                        </div>

                        <div class="checkbox-custom">
                            <input type="checkbox" class="modern-checkbox" id="option-correct-{{@index}}" {{#if this.isCorrect}}checked{{/if}}>
                            <label for="option-correct-{{@index}}">إجابة صحيحة</label>
                        </div>
                    </div>
                    {{/each}}
                </div>
                <button type="button" class="modern-btn modern-btn-success" onclick="addNewOption()">
                    <i class="fas fa-plus"></i> إضافة خيار
                </button>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="modern-btn modern-btn-primary" id="submitBtn">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
                <a href="/quiz/lesson/{{quiz.lessonId}}" class="modern-btn modern-btn-secondary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

<form action="/quiz/delete/{{quiz._id}}?_method=DELETE" method="post" id="deleteForm" style="display: none;"></form>

<style>
    * { direction: rtl; text-align: right; }

    :root {
        --primary: #6366f1; --primary-dark: #4f46e5; --primary-light: #eef2ff;
        --success: #10b981; --success-light: #d1fae5;
        --warning: #f59e0b; --warning-light: #fef3c7;
        --danger: #ef4444; --danger-light: #fee2e2;
        --info: #3b82f6; --info-light: #dbeafe;
        --gray-50: #f9fafb; --gray-100: #f3f4f6; --gray-200: #e5e7eb;
        --gray-300: #d1d5db; --gray-400: #9ca3af; --gray-500: #6b7280;
        --gray-600: #4b5563; --gray-700: #374151; --gray-800: #1f2937;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-md: 0.5rem; --radius-lg: 0.75rem; --radius-xl: 1rem;
    }

    .modern-card { background: white; border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); overflow: hidden; margin: 1.5rem; }
    .modern-card-header { padding: 1.5rem 2rem; background: linear-gradient(135deg, var(--gray-50) 0%, white 100%); border-bottom: 1px solid var(--gray-200); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .header-actions { display: flex; gap: 0.75rem; }
    .modern-title-section { display: flex; align-items: center; gap: 1rem; }
    .modern-icon-wrapper { width: 48px; height: 48px; border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .bg-warning-light { background: var(--warning-light); }
    .text-warning { color: var(--warning); }
    .modern-title { font-size: 1.25rem; font-weight: 600; color: var(--gray-800); margin: 0 0 0.25rem 0; }
    .modern-subtitle { font-size: 0.875rem; color: var(--gray-500); margin: 0; }
    .modern-card-body { padding: 2rem; }
    .modern-form { max-width: 100%; }
    .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-bottom: 1.5rem; }
    .full-width { grid-column: span 2; margin-bottom: 1.5rem; }
    @media (max-width: 768px) {
        .form-grid { grid-template-columns: 1fr; }
        .full-width { grid-column: span 1; }
        .modern-card { margin: 1rem; }
        .modern-card-header, .modern-card-body { padding: 1rem; }
    }
    .form-group-modern { margin-bottom: 0; }
    .form-label { display: block; font-size: 0.875rem; font-weight: 500; color: var(--gray-700); margin-bottom: 0.5rem; }
    .required { color: var(--danger); }
    .input-wrapper { position: relative; }
    .input-icon { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--gray-400); font-size: 1rem; pointer-events: none; }
    .textarea-icon { top: 1rem; transform: none; }
    .modern-input { width: 100%; padding: 0.75rem 2.5rem 0.75rem 1rem; border: 1.5px solid var(--gray-200); border-radius: var(--radius-md); font-size: 0.875rem; color: var(--gray-700); background: white; transition: all 0.2s ease; }
    .modern-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }
    .modern-textarea { padding: 1rem 2.5rem 1rem 1rem; resize: vertical; }
    .media-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .media-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: var(--radius-md); font-size: 0.75rem; font-weight: 500; cursor: pointer; border: none; transition: all 0.2s ease; }
    .media-btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .media-btn-image { background: var(--info-light); color: var(--info); }
    .media-btn-image:hover:not(:disabled) { background: var(--info); color: white; }
    .media-btn-video { background: var(--danger-light); color: var(--danger); }
    .media-btn-video:hover:not(:disabled) { background: var(--danger); color: white; }
    .media-btn-audio { background: var(--warning-light); color: var(--warning); }
    .media-btn-audio:hover:not(:disabled) { background: var(--warning); color: white; }
    .media-preview-container { margin-top: 0.5rem; }
    .media-preview { background: var(--gray-100); border-radius: var(--radius-md); padding: 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
    .media-preview img, .media-preview video { max-width: 100%; max-height: 200px; border-radius: var(--radius-md); }
    .media-preview audio { width: 100%; }
    .existing-media { border: 2px solid var(--success-light); }
    .upload-progress { width: 100%; background: var(--gray-200); border-radius: 1rem; height: 8px; overflow: hidden; }
    .upload-progress-bar { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-dark)); border-radius: 1rem; transition: width 0.3s ease; }
    .upload-status { font-size: 0.75rem; color: var(--gray-500); text-align: center; }
    .wasabi-badge { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.7rem; background: #e0f2fe; color: #0369a1; padding: 0.15rem 0.5rem; border-radius: 1rem; }
    .options-container { margin-bottom: 1rem; }
    .option-item { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1rem; transition: all 0.2s ease; }
    .option-item:hover { border-color: var(--primary-light); box-shadow: var(--shadow-sm); }
    .option-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--gray-200); }
    .option-number { font-size: 0.75rem; font-weight: 600; color: var(--primary); background: var(--primary-light); padding: 0.25rem 0.75rem; border-radius: 2rem; }
    .option-media-section { margin-top: 0.75rem; }
    .checkbox-custom { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; padding: 0.5rem 0; margin-top: 0.75rem; }
    .checkbox-custom input { width: 18px; height: 18px; cursor: pointer; accent-color: var(--success); }
    .checkbox-custom label { font-size: 0.875rem; color: var(--gray-700); cursor: pointer; margin: 0; }
    .modern-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; font-size: 0.875rem; font-weight: 500; border-radius: var(--radius-md); transition: all 0.2s ease; cursor: pointer; border: none; text-decoration: none; }
    .modern-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none !important; }
    .modern-btn-primary { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: white; box-shadow: var(--shadow-sm); }
    .modern-btn-primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: var(--shadow-md); color: white; }
    .modern-btn-secondary { background: var(--gray-100); color: var(--gray-600); border: 1px solid var(--gray-200); }
    .modern-btn-secondary:hover { background: var(--gray-200); color: var(--gray-700); }
    .modern-btn-success { background: linear-gradient(135deg, var(--success) 0%, #059669 100%); color: white; }
    .modern-btn-success:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); color: white; }
    .modern-btn-danger { background: linear-gradient(135deg, var(--danger) 0%, #dc2626 100%); color: white; }
    .modern-btn-danger:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); color: white; }
    .form-actions { display: flex; gap: 1rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--gray-200); }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
// ─── État initial à partir des données existantes du quiz ─────────────────────
// optionMediaData est pré-rempli avec les médias des options existantes
let optionMediaData = {};
{{#each quiz.options}}
{{#if this.mediaUrl}}
optionMediaData[{{@index}}] = { url: '{{this.mediaUrl}}', type: '{{this.mediaType}}' };
{{/if}}
{{/each}}

let newOptionCounter = 0;  // pour les nouvelles options ajoutées dynamiquement
let activeUploads = 0;

// ─── Helpers ──────────────────────────────────────────────────────────────────

function trackUpload(delta) {
    activeUploads += delta;
    const btn = document.getElementById('submitBtn');
    if (activeUploads > 0) {
        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> جاري رفع الملفات (${activeUploads})...`;
    } else {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> حفظ التعديلات';
    }
}

function getMediaType(file) {
    if (file.type.startsWith('image/')) return 'image';
    if (file.type.startsWith('video/')) return 'video';
    if (file.type.startsWith('audio/')) return 'audio';
    return 'image';
}

function getFileExt(file) {
    return file.name.split('.').pop().toLowerCase();
}

function renderMediaPreview(url, type) {
    if (type === 'image') return `<img src="${url}" alt="Preview">`;
    if (type === 'video') return `<video src="${url}" controls></video>`;
    return `<audio src="${url}" controls></audio>`;
}

// ─── Upload vers Wasabi via URL présignée ──────────────────────────────────────

async function uploadToWasabi(file, previewContainer, onSuccess) {
    const type = getMediaType(file);
    const ext  = getFileExt(file);

    previewContainer.innerHTML = `
        <div class="media-preview">
            <div class="upload-status"><i class="fas fa-cloud-upload-alt"></i> جاري الرفع إلى Wasabi...</div>
            <div class="upload-progress"><div class="upload-progress-bar" id="pbar_${Date.now()}" style="width:5%"></div></div>
        </div>`;
    const progressBar = previewContainer.querySelector('[id^="pbar_"]');

    trackUpload(+1);
    try {
        const presignRes = await fetch(`/quiz/upload/presign?type=${type}&ext=${ext}`);
        const presignData = await presignRes.json();
        if (!presignData.success) throw new Error(presignData.error || 'Erreur presign');

        if (progressBar) progressBar.style.width = '30%';

        await new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            xhr.open('PUT', presignData.uploadUrl, true);
            xhr.setRequestHeader('Content-Type', file.type);
            xhr.upload.onprogress = (e) => {
                if (e.lengthComputable && progressBar) {
                    progressBar.style.width = (30 + Math.round((e.loaded / e.total) * 65)) + '%';
                }
            };
            xhr.onload = () => xhr.status < 300 ? resolve() : reject(new Error('Wasabi upload failed: ' + xhr.status));
            xhr.onerror = () => reject(new Error('Network error'));
            xhr.send(file);
        });

        if (progressBar) progressBar.style.width = '100%';
        onSuccess(presignData.publicUrl, presignData.proxyUrl, type);

        previewContainer.innerHTML = `
            <div class="media-preview">
                ${renderMediaPreview(presignData.proxyUrl, type)}
                <span class="wasabi-badge"><i class="fas fa-cloud"></i> Wasabi</span>
            </div>`;

    } catch (err) {
        previewContainer.innerHTML = '';
        Swal.fire({ icon: 'error', title: 'خطأ في الرفع', text: err.message });
    } finally {
        trackUpload(-1);
    }
}

// ─── Média de la question ──────────────────────────────────────────────────────

function uploadQuestionMedia(type) {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = type === 'image' ? 'image/*' : (type === 'video' ? 'video/*' : 'audio/*');
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const previewDiv = document.getElementById('questionMediaPreview');
        await uploadToWasabi(file, previewDiv, (publicUrl, proxyUrl, mediaType) => {
            document.getElementById('subQuestion').value = publicUrl;
            document.getElementById('questionMediaType').value = mediaType;
            document.getElementById('questionMediaUrl').value = publicUrl;
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'modern-btn modern-btn-danger';
            btn.innerHTML = '<i class="fas fa-trash"></i> حذف الميديا';
            btn.onclick = removeQuestionMedia;
            previewDiv.querySelector('.media-preview').appendChild(btn);
        });
    };
    input.click();
}

function removeQuestionMedia() {
    document.getElementById('questionMediaPreview').innerHTML = '';
    document.getElementById('subQuestion').value = '';
    document.getElementById('questionMediaType').value = 'text';
    document.getElementById('questionMediaUrl').value = '';
}

// ─── Média des options existantes ────────────────────────────────────────────

async function uploadOptionMedia(optionId, type) {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = type === 'image' ? 'image/*' : (type === 'video' ? 'video/*' : 'audio/*');
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const previewDiv = document.getElementById(`option-media-preview-${optionId}`);
        await uploadToWasabi(file, previewDiv, (publicUrl, proxyUrl, mediaType) => {
            optionMediaData[optionId] = { url: publicUrl, type: mediaType };
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'modern-btn modern-btn-danger';
            btn.innerHTML = '<i class="fas fa-trash"></i> حذف';
            btn.onclick = () => removeOptionMedia(optionId);
            previewDiv.querySelector('.media-preview').appendChild(btn);
        });
    };
    input.click();
}

function removeOptionMedia(optionId) {
    document.getElementById(`option-media-preview-${optionId}`).innerHTML = '';
    delete optionMediaData[optionId];
}

function removeOption(id) {
    const optionDiv = document.getElementById(`option-${id}`);
    if (optionDiv) optionDiv.remove();
    delete optionMediaData[id];
}

// ─── Ajouter une nouvelle option ──────────────────────────────────────────────

function addNewOption() {
    const container = document.getElementById('optionsContainer');
    const newId = 'new_' + Date.now();
    const optionDiv = document.createElement('div');
    optionDiv.className = 'option-item';
    optionDiv.id = `option-${newId}`;
    optionDiv.innerHTML = `
        <div class="option-header">
            <span class="option-number">خيار جديد</span>
            <button type="button" class="modern-btn modern-btn-danger" style="padding: 0.25rem 0.75rem;" onclick="this.closest('.option-item').remove(); delete optionMediaData['${newId}']">
                <i class="fas fa-trash"></i> حذف
            </button>
        </div>
        <div class="option-content">
            <div class="input-wrapper">
                <i class="fas fa-font input-icon"></i>
                <input type="text" class="modern-input new-option-text" placeholder="نص الخيار">
            </div>
        </div>
        <div class="option-media-section">
            <label style="font-size:0.8rem;color:var(--gray-500);margin-bottom:0.4rem;display:block;">ميديا الخيار (اختياري)</label>
            <div id="option-media-preview-${newId}" class="media-preview-container"></div>
            <div class="media-buttons" style="margin-top:0.5rem;">
                <button type="button" class="media-btn media-btn-image" onclick="uploadOptionMedia('${newId}', 'image')">
                    <i class="fas fa-image"></i> صورة
                </button>
                <button type="button" class="media-btn media-btn-video" onclick="uploadOptionMedia('${newId}', 'video')">
                    <i class="fas fa-video"></i> فيديو
                </button>
                <button type="button" class="media-btn media-btn-audio" onclick="uploadOptionMedia('${newId}', 'audio')">
                    <i class="fas fa-headphones"></i> صوت
                </button>
            </div>
        </div>
        <div class="checkbox-custom">
            <input type="checkbox" class="new-option-correct">
            <label>إجابة صحيحة</label>
        </div>
    `;
    container.appendChild(optionDiv);
}

// ─── Confirmation suppression ─────────────────────────────────────────────────

function confirmDelete() {
    Swal.fire({
        title: 'تأكيد الحذف',
        text: 'هل أنت متأكد من حذف هذا الاختبار؟',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'نعم، احذف',
        cancelButtonText: 'إلغاء'
    }).then(result => {
        if (result.isConfirmed) document.getElementById('deleteForm').submit();
    });
}

// ─── Soumission ────────────────────────────────────────────────────────────────

document.getElementById('quizForm').addEventListener('submit', function(e) {
    e.preventDefault();

    if (activeUploads > 0) {
        Swal.fire({ icon: 'warning', title: 'انتظر', text: 'جاري رفع الملفات، يرجى الانتظار...' });
        return;
    }

    const options = [];
    let index = 0;

    document.querySelectorAll('#optionsContainer .option-item').forEach(div => {
        const id = div.id.replace('option-', '');
        let text, isCorrect;

        if (id.startsWith('new_')) {
            // Nouvelle option ajoutée dynamiquement
            text = div.querySelector('.new-option-text')?.value.trim();
            isCorrect = div.querySelector('.new-option-correct')?.checked || false;
        } else {
            // Option existante (index numérique)
            text = document.getElementById(`option-text-${id}`)?.value.trim();
            isCorrect = document.getElementById(`option-correct-${id}`)?.checked || false;
        }

        if (!text) return;

        const media = optionMediaData[id] || { url: '', type: 'text' };
        options.push({
            _id: div.dataset.optionId || ('opt_' + Date.now() + '_' + index),
            content: text,
            isCorrect: isCorrect,
            mediaType: media.url ? media.type : 'text',
            mediaUrl: media.url || ''
        });
        index++;
    });

    if (options.length < 2) {
        Swal.fire({ icon: 'error', title: 'خطأ', text: 'يجب إضافة خيارين على الأقل' });
        return;
    }
    if (!options.some(opt => opt.isCorrect)) {
        Swal.fire({ icon: 'error', title: 'خطأ', text: 'يجب تحديد إجابة صحيحة واحدة على الأقل' });
        return;
    }

    document.getElementById('optionsData').value = JSON.stringify(options);
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
    this.submit();
});
</script>
