<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-warning-light">
                <i class="fas fa-edit text-warning"></i>
            </div>
            <div>
                <h3 class="modern-title">تعديل الاختبار</h3>
                <p class="modern-subtitle">تعديل السؤال والخيارات</p>
            </div>
        </div>
        <div class="header-actions">
            <a href="/quiz/lesson/{{quiz.lessonId}}" class="modern-btn modern-btn-secondary">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
            <button type="button" class="modern-btn modern-btn-danger" onclick="confirmDelete()">
                <i class="fas fa-trash"></i> حذف
            </button>
        </div>
    </div>
    
    <div class="modern-card-body">
        <form action="/quiz/update/{{quiz._id}}?_method=PUT" method="post" id="quizForm" class="modern-form">
            <input type="hidden" name="lessonId" value="{{quiz.lessonId}}">
            <input type="hidden" name="options" id="optionsData">
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="order" class="form-label">الترتيب</label>
                    <div class="input-wrapper">
                        <i class="fas fa-sort-numeric-down input-icon"></i>
                        <input type="number" class="modern-input" id="order" name="order" value="{{quiz.order}}" min="0">
                    </div>
                </div>
                
                <div class="form-group-modern">
                    <label for="point" class="form-label">النقاط</label>
                    <div class="input-wrapper">
                        <i class="fas fa-star input-icon"></i>
                        <input type="number" class="modern-input" id="point" name="point" value="{{quiz.point}}" min="1">
                    </div>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="typeQuiz" class="form-label">
                    نوع الاختبار <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <i class="fas fa-list-ul input-icon"></i>
                    <select class="modern-input" id="typeQuiz" name="typeQuiz" required>
                        <option value="SINGLESELECT" {{#if (eq quiz.typeQuiz 'SINGLESELECT')}}selected{{/if}}>اختيار من متعدد (إجابة واحدة)</option>
                        <option value="MULTISELECT" {{#if (eq quiz.typeQuiz 'MULTISELECT')}}selected{{/if}}>اختيار من متعدد (إجابات متعددة)</option>
                    </select>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="question" class="form-label">
                    السؤال <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <i class="fas fa-question-circle input-icon"></i>
                    <input type="text" class="modern-input" id="question" name="question" value="{{quiz.question}}" required>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="explanation" class="form-label">شرح الإجابة</label>
                <div class="input-wrapper">
                    <i class="fas fa-align-right input-icon textarea-icon"></i>
                    <textarea class="modern-input modern-textarea" id="explanation" name="explanation" rows="3">{{quiz.explanation}}</textarea>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label class="form-label">الخيارات <span class="required">*</span></label>
                <div id="optionsContainer" class="options-container">
                    {{#each quiz.options}}
                    <div class="option-item" id="option-{{@index}}">
                        <div class="option-header">
                            <span class="option-number">الخيار {{inc @index}}</span>
                            <button type="button" class="modern-btn modern-btn-danger" style="padding: 0.25rem 0.75rem;" onclick="removeOption({{@index}})">
                                <i class="fas fa-trash"></i> حذف
                            </button>
                        </div>
                        <div class="option-content">
                            <div class="input-wrapper">
                                <i class="fas fa-font input-icon"></i>
                                <input type="text" class="modern-input" id="option-text-{{@index}}" value="{{this.content}}" required>
                            </div>
                        </div>
                        <div class="checkbox-custom">
                            <input type="checkbox" class="modern-checkbox" id="option-correct-{{@index}}" {{#if this.isCorrect}}checked{{/if}}>
                            <label for="option-correct-{{@index}}">إجابة صحيحة</label>
                        </div>
                    </div>
                    {{/each}}
                </div>
                <button type="button" class="modern-btn modern-btn-success" onclick="addOption()">
                    <i class="fas fa-plus"></i> إضافة خيار
                </button>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="modern-btn modern-btn-primary">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
                <a href="/quiz/lesson/{{quiz.lessonId}}" class="modern-btn modern-btn-secondary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

<form action="/quiz/delete/{{quiz._id}}?_method=DELETE" method="post" id="deleteForm" style="display: none;"></form>

