<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-primary-light">
                <i class="fas fa-question-circle text-primary"></i>
            </div>
            <div>
                <h3 class="modern-title">قائمة الاختبارات</h3>
                <p class="modern-subtitle">إدارة وعرض جميع الاختبارات حسب الدروس</p>
            </div>
        </div>
        <button type="button" class="modern-btn modern-btn-success" onclick="openCreateModal()">
            <i class="fas fa-plus"></i> إنشاء اختبار
        </button>
    </div>
    
    <div class="modern-card-body">
        <!-- إحصائيات -->
        <div class="stats-grid">
            <div class="stat-card modern">
                <div class="stat-icon bg-primary-light">
                    <i class="fas fa-question-circle text-primary"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.totalQuizzes}}</div>
                    <div class="stat-label">إجمالي الاختبارات</div>
                </div>
            </div>
            <div class="stat-card modern">
                <div class="stat-icon bg-success-light">
                    <i class="fas fa-chalkboard-teacher text-success"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.totalLessonsWithQuizzes}}</div>
                    <div class="stat-label">دروس بها اختبارات</div>
                </div>
            </div>
            <div class="stat-card modern">
                <div class="stat-icon bg-warning-light">
                    <i class="fas fa-dot-circle text-warning"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.singleselect}}</div>
                    <div class="stat-label">اختيار واحد</div>
                </div>
            </div>
            <div class="stat-card modern">
                <div class="stat-icon bg-danger-light">
                    <i class="fas fa-check-double text-danger"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{stats.multiselect}}</div>
                    <div class="stat-label">متعدد الإجابات</div>
                </div>
            </div>
        </div>
        
        <!-- فلتر البحث -->
        <div class="filter-section">
            <div class="filter-group">
                <label class="filter-label">
                    <i class="fas fa-search"></i> بحث
                </label>
                <input type="text" id="searchInput" class="modern-filter" placeholder="ابحث عن درس أو مادة أو سنة...">
            </div>
            <div class="filter-actions">
                <button id="resetSearch" class="modern-btn modern-btn-sm modern-btn-secondary">
                    <i class="fas fa-undo"></i> إعادة تعيين
                </button>
            </div>
        </div>
        
        <!-- جدول الدروس -->
        <div class="table-wrapper">
            <table class="modern-table" id="lessonsTable">
                <thead>
                    <tr>
                        <th class="col-number">#</th>
                        <th>الدرس</th>
                        <th>المادة</th>
                        <th>السنة</th>
                        <th class="text-center">عدد الاختبارات</th>
                        <th class="text-center">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each lessonsWithQuizzes}}
                    <tr data-lesson-name="{{this.lessonName}}" data-subject="{{this.subjectName}}" data-branch="{{this.branchName}}">
                        <td class="text-center">{{inc @index}}</td>
                        <td>
                            <div class="lesson-info">
                                <div class="lesson-icon">
                                    <i class="fas fa-play-circle"></i>
                                </div>
                                <strong>{{this.lessonName}}</strong>
                            </div>
                        </td>
                        <td><span class="badge-modern badge-subject">{{this.subjectName}}</span></td>
                        <td><span class="badge-modern badge-branch">{{this.branchName}}</span></td>
                        <td class="text-center">
                            <span class="quiz-count-badge">{{this.quizCount}}</span>
                        </td>
                        <td class="text-center">
                            <div class="action-buttons">
                                <a href="/quiz/lesson/{{this.lessonId}}" class="action-btn action-view">
                                    <i class="fas fa-list"></i>
                                    <span>عرض</span>
                                </a>
                                <a href="/quiz/create/{{this.lessonId}}" class="action-btn action-add">
                                    <i class="fas fa-plus"></i>
                                    <span>إضافة</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <p>لا توجد اختبارات حالياً</p>
                                <button onclick="openCreateModal()" class="modern-btn modern-btn-primary">إنشاء أول اختبار</button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ==================== MODAL إنشاء اختبار ==================== -->
<div class="modal-overlay" id="createQuizModal" style="display: none;">
    <div class="modal-container">
        <div class="modal-header">
            <div class="modal-title-section">
                <div class="modal-icon">
                    <i class="fas fa-plus-circle"></i>
                </div>
                <h3>إنشاء اختبار جديد — اختر الدرس</h3>
            </div>
            <button class="modal-close" onclick="closeCreateModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group-modern">
                <label class="form-label">
                    <i class="fas fa-search"></i> بحث عن الدرس
                </label>
                <input type="text" id="lessonSearch" class="modern-input" placeholder="اكتب اسم الدرس أو المادة أو السنة...">
            </div>
            
            <div class="lessons-list" id="lessonsListContainer">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>الدرس</th>
                            <th>المادة</th>
                            <th>السنة</th>
                            <th class="text-center">إجراء</th>
                        </tr>
                    </thead>
                    <tbody id="lessonsTableBody">
                        {{#each allLessons}}
                        <tr class="lesson-row"
                            data-lesson-id="{{this._id}}"
                            data-lesson-name="{{this.name}}"
                            data-subject="{{this.subjectId.name}}"
                            data-branch="{{this.branchId.name}}">
                            <td><strong>{{this.name}}</strong></td>
                            <td><span class="badge-modern badge-subject">{{this.subjectId.name}}</span></td>
                            <td><span class="badge-modern badge-branch">{{this.branchId.name}}</span></td>
                            <td class="text-center">
                                <a href="/quiz/create/{{this._id}}" class="action-btn action-add">
                                    <i class="fas fa-plus"></i> إنشاء اختبار
                                </a>
                            </td>
                        </tr>
                        {{else}}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-3">
                                <i class="fas fa-exclamation-circle"></i> لا توجد دروس متاحة
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                <div id="noLessonsFound" class="empty-state-small" style="display:none;">
                    <i class="fas fa-search"></i>
                    <p>لم يتم العثور على درس مطابق</p>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="modern-btn modern-btn-secondary" onclick="closeCreateModal()">
                <i class="fas fa-times"></i> إغلاق
            </button>
        </div>
    </div>
</div>

