<script>
function openCreateModal() {
    document.getElementById('createQuizModal').style.display = 'flex';
}

function closeCreateModal() {
    document.getElementById('createQuizModal').style.display = 'none';
    document.getElementById('lessonSearch').value = '';
    document.querySelectorAll('.lesson-row').forEach(row => row.style.display = '');
    document.getElementById('noLessonsFound').style.display = 'none';
}

// Search filter for main table
const searchInput = document.getElementById('searchInput');
if (searchInput) {
    searchInput.addEventListener('input', function() {
        const query = this.value.trim().toLowerCase();
        const rows = document.querySelectorAll('#lessonsTable tbody tr');
        let visibleCount = 0;
        
        rows.forEach(row => {
            if (row.querySelector('.empty-state')) return;
            const lessonName = (row.getAttribute('data-lesson-name') || '').toLowerCase();
            const subject = (row.getAttribute('data-subject') || '').toLowerCase();
            const branch = (row.getAttribute('data-branch') || '').toLowerCase();
            
            if (!query || lessonName.includes(query) || subject.includes(query) || branch.includes(query)) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
    });
}

// Reset search
const resetBtn = document.getElementById('resetSearch');
if (resetBtn) {
    resetBtn.addEventListener('click', function() {
        if (searchInput) searchInput.value = '';
        const rows = document.querySelectorAll('#lessonsTable tbody tr');
        rows.forEach(row => row.style.display = '');
    });
}

// Modal search
const lessonSearch = document.getElementById('lessonSearch');
if (lessonSearch) {
    lessonSearch.addEventListener('input', function() {
        const query = this.value.trim().toLowerCase();
        const rows = document.querySelectorAll('#lessonsTableBody .lesson-row');
        let visibleCount = 0;
        
        rows.forEach(row => {
            const lessonName = (row.getAttribute('data-lesson-name') || '').toLowerCase();
            const subject = (row.getAttribute('data-subject') || '').toLowerCase();
            const branch = (row.getAttribute('data-branch') || '').toLowerCase();
            
            if (!query || lessonName.includes(query) || subject.includes(query) || branch.includes(query)) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
        
        const noLessonsDiv = document.getElementById('noLessonsFound');
        if (noLessonsDiv) {
            noLessonsDiv.style.display = (visibleCount === 0 && rows.length > 0) ? 'block' : 'none';
        }
    });
}

// Close modal on click outside
document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
        if (e.target === this) closeCreateModal();
    });
});
</script>