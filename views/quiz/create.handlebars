<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
let optionCount = 0;
let currentQuizId = null;
let questionMediaUrl = null;
let optionMediaFiles = {};

function resetForm() {
    optionCount = 0;
    optionMediaFiles = {};
    questionMediaUrl = null;
    document.getElementById('optionsContainer').innerHTML = '<div class="empty-options"><i class="fas fa-plus-circle"></i><p>انقر على "إضافة خيار" لإضافة الخيارات</p></div>';
    document.getElementById('questionMediaPreview').innerHTML = '';
    document.getElementById('subQuestion').value = '';
    document.getElementById('question').value = '';
    document.getElementById('explanation').value = '';
}

async function uploadQuestionMedia(type) {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = type === 'image' ? 'image/*' : (type === 'video' ? 'video/*' : 'audio/*');
    
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        const formData = new FormData();
        formData.append('file', file);
        formData.append('mediaType', type);
        if (currentQuizId) formData.append('quizId', currentQuizId);
        
        const previewDiv = document.getElementById('questionMediaPreview');
        previewDiv.innerHTML = '<div class="media-preview"><i class="fas fa-spinner fa-spin"></i> جاري الرفع...</div>';
        
        try {
            const response = await fetch('/quiz/upload/question-media', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            
            if (result.success) {
                questionMediaUrl = result.mediaUrl;
                let mediaHtml = '';
                if (type === 'image') {
                    mediaHtml = `<img src="${result.mediaUrl}" alt="Preview">`;
                } else if (type === 'video') {
                    mediaHtml = `<video src="${result.mediaUrl}" controls></video>`;
                } else {
                    mediaHtml = `<audio src="${result.mediaUrl}" controls></audio>`;
                }
                previewDiv.innerHTML = `
                    <div class="media-preview">
                        ${mediaHtml}
                        <button type="button" class="modern-btn modern-btn-danger" onclick="removeQuestionMedia()">حذف</button>
                    </div>
                `;
                document.getElementById('subQuestion').value = result.mediaUrl;
            }
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'خطأ', text: error.message });
            previewDiv.innerHTML = '';
        }
    };
    input.click();
}

function removeQuestionMedia() {
    document.getElementById('questionMediaPreview').innerHTML = '';
    document.getElementById('subQuestion').value = '';
    questionMediaUrl = null;
}

function addOption() {
    optionCount++;
    const container = document.getElementById('optionsContainer');
    
    // Remove empty state if present
    const emptyDiv = container.querySelector('.empty-options');
    if (emptyDiv) emptyDiv.remove();
    
    const optionDiv = document.createElement('div');
    optionDiv.className = 'option-item';
    optionDiv.id = `option-${optionCount}`;
    optionDiv.innerHTML = `
        <div class="option-header">
            <span class="option-number">الخيار ${optionCount}</span>
            <button type="button" class="modern-btn modern-btn-danger" style="padding: 0.25rem 0.75rem;" onclick="removeOption(${optionCount})">
                <i class="fas fa-trash"></i> حذف
            </button>
        </div>
        <div class="option-content">
            <div class="input-wrapper">
                <i class="fas fa-font input-icon"></i>
                <input type="text" class="modern-input" id="option-text-${optionCount}" placeholder="نص الخيار" required>
            </div>
        </div>
        <div class="option-media-section">
            <div class="media-buttons" style="margin-bottom: 0.5rem;">
                <button type="button" class="media-btn media-btn-image" onclick="uploadOptionMedia(${optionCount}, 'image')">
                    <i class="fas fa-image"></i> صورة
                </button>
                <button type="button" class="media-btn media-btn-video" onclick="uploadOptionMedia(${optionCount}, 'video')">
                    <i class="fas fa-video"></i> فيديو
                </button>
                <button type="button" class="media-btn media-btn-audio" onclick="uploadOptionMedia(${optionCount}, 'audio')">
                    <i class="fas fa-headphones"></i> صوت
                </button>
            </div>
            <div id="option-media-preview-${optionCount}" class="media-preview-container"></div>
        </div>
        <div class="checkbox-custom">
            <input type="checkbox" id="option-correct-${optionCount}">
            <label for="option-correct-${optionCount}">إجابة صحيحة</label>
        </div>
    `;
    container.appendChild(optionDiv);
}

async function uploadOptionMedia(optionId, type) {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = type === 'image' ? 'image/*' : (type === 'video' ? 'video/*' : 'audio/*');
    
    input.onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        const formData = new FormData();
        formData.append('file', file);
        formData.append('mediaType', type);
        if (currentQuizId) formData.append('quizId', currentQuizId);
        
        const previewDiv = document.getElementById(`option-media-preview-${optionId}`);
        previewDiv.innerHTML = '<div class="media-preview"><i class="fas fa-spinner fa-spin"></i> جاري الرفع...</div>';
        
        try {
            const response = await fetch('/quiz/upload/option-media', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            
            if (result.success) {
                optionMediaFiles[optionId] = result.mediaUrl;
                let mediaHtml = '';
                if (type === 'image') {
                    mediaHtml = `<img src="${result.mediaUrl}" alt="Preview">`;
                } else if (type === 'video') {
                    mediaHtml = `<video src="${result.mediaUrl}" controls></video>`;
                } else {
                    mediaHtml = `<audio src="${result.mediaUrl}" controls></audio>`;
                }
                previewDiv.innerHTML = `
                    <div class="media-preview">
                        ${mediaHtml}
                        <button type="button" class="modern-btn modern-btn-danger" onclick="removeOptionMedia(${optionId})">حذف</button>
                    </div>
                `;
            }
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'خطأ', text: error.message });
            previewDiv.innerHTML = '';
        }
    };
    input.click();
}

function removeOptionMedia(optionId) {
    document.getElementById(`option-media-preview-${optionId}`).innerHTML = '';
    delete optionMediaFiles[optionId];
}

function removeOption(id) {
    const optionDiv = document.getElementById(`option-${id}`);
    if (optionDiv) optionDiv.remove();
    delete optionMediaFiles[id];
    
    // Check if no options left
    const container = document.getElementById('optionsContainer');
    if (container.children.length === 0) {
        container.innerHTML = '<div class="empty-options"><i class="fas fa-plus-circle"></i><p>انقر على "إضافة خيار" لإضافة الخيارات</p></div>';
    }
}

document.getElementById('quizForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const options = [];
    for (let i = 1; i <= optionCount; i++) {
        const optionDiv = document.getElementById(`option-${i}`);
        if (!optionDiv) continue;
        
        const text = document.getElementById(`option-text-${i}`)?.value.trim();
        if (!text) continue;
        
        const isCorrect = document.getElementById(`option-correct-${i}`)?.checked || false;
        const mediaUrl = optionMediaFiles[i] || '';
        let mediaType = 'text';
        
        if (mediaUrl) {
            if (mediaUrl.includes('.mp4') || mediaUrl.includes('.webm')) {
                mediaType = 'video';
            } else if (mediaUrl.includes('.mp3') || mediaUrl.includes('.wav')) {
                mediaType = 'audio';
            } else {
                mediaType = 'image';
            }
        }
        
        options.push({
            _id: 'opt_' + Date.now() + '_' + i,
            content: text,
            isCorrect: isCorrect,
            mediaType: mediaType,
            mediaUrl: mediaUrl
        });
    }
    
    if (options.length < 2) {
        Swal.fire({ icon: 'error', title: 'خطأ', text: 'يجب إضافة خيارين على الأقل' });
        return;
    }
    
    const hasCorrect = options.some(opt => opt.isCorrect);
    if (!hasCorrect) {
        Swal.fire({ icon: 'error', title: 'خطأ', text: 'يجب تحديد إجابة صحيحة واحدة على الأقل' });
        return;
    }
    
    document.getElementById('optionsData').value = JSON.stringify(options);
    this.submit();
});
</script>