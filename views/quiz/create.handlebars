<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-primary-light">
                <i class="fas fa-plus-circle text-primary"></i>
            </div>
            <div>
                <h3 class="modern-title">إنشاء اختبار جديد</h3>
                <p class="modern-subtitle">أضف سؤالاً جديداً مع خيارات الإجابة</p>
            </div>
        </div>
        <a href="/quiz/lesson/{{lessonId}}" class="modern-btn modern-btn-secondary">
            <i class="fas fa-arrow-right"></i> رجوع
        </a>
    </div>
    
    <div class="modern-card-body">
        <div class="modern-info-box">
            <i class="fas fa-info-circle"></i>
            <div>
                <strong>معلومات:</strong> يمكنك إضافة صور، فيديوهات أو صوت للأسئلة والخيارات
            </div>
        </div>
        
        <form action="/quiz/create" method="post" id="quizForm" class="modern-form">
            <input type="hidden" name="lessonId" value="{{lessonId}}">
            <input type="hidden" name="options" id="optionsData">
            
            <div class="form-grid">
                <div class="form-group-modern">
                    <label for="order" class="form-label">الترتيب</label>
                    <div class="input-wrapper">
                        <i class="fas fa-sort-numeric-down input-icon"></i>
                        <input type="number" class="modern-input" id="order" name="order" value="{{nextOrder}}" min="0" placeholder="0">
                    </div>
                    <span class="form-hint">كلما كان الرقم أصغر، ظهر السؤال أولاً</span>
                </div>
                
                <div class="form-group-modern">
                    <label for="point" class="form-label">النقاط</label>
                    <div class="input-wrapper">
                        <i class="fas fa-star input-icon"></i>
                        <input type="number" class="modern-input" id="point" name="point" value="1" min="1" placeholder="1">
                    </div>
                    <span class="form-hint">عدد النقاط الممنوحة للإجابة الصحيحة</span>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="typeQuiz" class="form-label">
                    نوع الاختبار <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <i class="fas fa-list-ul input-icon"></i>
                    <select class="modern-input" id="typeQuiz" name="typeQuiz" required>
                        <option value="SINGLESELECT">اختيار من متعدد (إجابة واحدة)</option>
                        <option value="MULTISELECT">اختيار من متعدد (إجابات متعددة)</option>
                    </select>
                </div>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="question" class="form-label">
                    السؤال <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <i class="fas fa-question-circle input-icon"></i>
                    <input type="text" class="modern-input" id="question" name="question" required placeholder="أدخل نص السؤال...">
                </div>
            </div>
            
            <!-- ميديا السؤال -->
            <div class="form-group-modern full-width">
                <label class="form-label">ميديا السؤال (صورة/فيديو/صوت)</label>
                <div class="media-buttons">
                    <button type="button" class="media-btn media-btn-image" onclick="uploadQuestionMedia('image')">
                        <i class="fas fa-image"></i> إضافة صورة
                    </button>
                    <button type="button" class="media-btn media-btn-video" onclick="uploadQuestionMedia('video')">
                        <i class="fas fa-video"></i> إضافة فيديو
                    </button>
                    <button type="button" class="media-btn media-btn-audio" onclick="uploadQuestionMedia('audio')">
                        <i class="fas fa-headphones"></i> إضافة صوت
                    </button>
                </div>
                <div id="questionMediaPreview" class="media-preview-container"></div>
                <input type="hidden" name="subQuestion" id="subQuestion">
            </div>
            
            <!-- الخيارات -->
            <div class="form-group-modern full-width">
                <label class="form-label">الخيارات <span class="required">*</span></label>
                <div id="optionsContainer" class="options-container">
                    <div class="empty-options">
                        <i class="fas fa-plus-circle"></i>
                        <p>انقر على "إضافة خيار" لإضافة الخيارات</p>
                    </div>
                </div>
                <button type="button" class="modern-btn modern-btn-success" onclick="addOption()">
                    <i class="fas fa-plus"></i> إضافة خيار
                </button>
                <span class="form-hint">أضف خيارين على الأقل وحدد الإجابة/الإجابات الصحيحة</span>
            </div>
            
            <div class="form-group-modern full-width">
                <label for="explanation" class="form-label">شرح الإجابة</label>
                <div class="input-wrapper">
                    <i class="fas fa-align-right input-icon textarea-icon"></i>
                    <textarea class="modern-input modern-textarea" id="explanation" name="explanation" rows="3" placeholder="شرح مختصر للإجابة الصحيحة..."></textarea>
                </div>
                <span class="form-hint">شرح يظهر للمستخدم بعد الإجابة (اختياري)</span>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="modern-btn modern-btn-primary">
                    <i class="fas fa-save"></i> حفظ الاختبار
                </button>
                <button type="reset" class="modern-btn modern-btn-secondary" onclick="resetForm()">
                    <i class="fas fa-undo"></i> إعادة تعيين
                </button>
            </div>
        </form>
    </div>
</div>

