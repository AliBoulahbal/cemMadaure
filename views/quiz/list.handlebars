<div class="modern-card">
    <div class="modern-card-header">
        <div class="modern-title-section">
            <div class="modern-icon-wrapper bg-primary-light">
                <i class="fas fa-question-circle text-primary"></i>
            </div>
            <div>
                <h3 class="modern-title">اختبارات: {{lesson.name}}</h3>
                <p class="modern-subtitle">إدارة أسئلة الاختبار لهذا الدرس</p>
            </div>
        </div>
        <div class="header-actions">
            <a href="/quiz" class="modern-btn modern-btn-secondary">
                <i class="fas fa-arrow-right"></i> رجوع
            </a>
            <a href="/quiz/create/{{lesson._id}}" class="modern-btn modern-btn-success">
                <i class="fas fa-plus"></i> إضافة سؤال
            </a>
        </div>
    </div>
    
    <div class="modern-card-body">
        <!-- معلومات الدرس -->
        <div class="lesson-info-cards">
            <div class="info-card-mini">
                <div class="info-icon-branch">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="info-content">
                    <span class="info-label-branch">السنة</span>
                    <span class="info-value-branch">{{lesson.branchId.name}}</span>
                </div>
            </div>
            <div class="info-card-mini">
                <div class="info-icon-subject">
                    <i class="fas fa-book"></i>
                </div>
                <div class="info-content">
                    <span class="info-label-subject">المادة</span>
                    <span class="info-value-subject">{{lesson.subjectId.name}}</span>
                </div>
            </div>
            <div class="info-card-mini">
                <div class="info-icon-unit">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div class="info-content">
                    <span class="info-label-unit">الوحدة</span>
                    <span class="info-value-unit">{{lesson.unitId.name}}</span>
                </div>
            </div>
        </div>
        
        <!-- إحصائيات سريعة -->
        <div class="stats-row-mini">
            <div class="stat-mini">
                <div class="stat-mini-number">{{stats.total}}</div>
                <div class="stat-mini-label">إجمالي الأسئلة</div>
            </div>
            <div class="stat-mini">
                <div class="stat-mini-number">{{stats.singleselect}}</div>
                <div class="stat-mini-label">اختيار واحد</div>
            </div>
            <div class="stat-mini">
                <div class="stat-mini-number">{{stats.multiselect}}</div>
                <div class="stat-mini-label">متعدد الإجابات</div>
            </div>
            <div class="stat-mini">
                <div class="stat-mini-number">{{stats.withMedia}}</div>
                <div class="stat-mini-label">مع وسائط</div>
            </div>
        </div>
        
        <!-- جدول الأسئلة -->
        <div class="table-wrapper">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th class="col-number">#</th>
                        <th>السؤال</th>
                        <th class="col-type">النوع</th>
                        <th class="col-points">النقاط</th>
                        <th class="col-order">الترتيب</th>
                        <th class="col-actions">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each quizzes}}
                    <tr>
                        <td class="text-center">{{inc @index}}</td>
                        <td>
                            <div class="question-info">
                                <div class="question-icon">
                                    <i class="fas fa-question-circle"></i>
                                </div>
                                <div class="question-details">
                                    <strong>{{this.question}}</strong>
                                    {{#if this.subQuestion}}
                                    <div class="question-media-indicator">
                                        <i class="fas fa-paperclip"></i> وسائط مرفقة
                                    </div>
                                    {{/if}}
                                </div>
                            </div>
                        </td>
                        <td>
                            {{#if (eq this.typeQuiz 'SINGLESELECT')}}
                                <span class="type-badge type-single">
                                    <i class="fas fa-dot-circle"></i> اختيار واحد
                                </span>
                            {{else}}
                                <span class="type-badge type-multi">
                                    <i class="fas fa-check-double"></i> متعدد
                                </span>
                            {{/if}}
                        </td>
                        <td class="text-center">
                            <span class="points-badge">{{this.point}}</span>
                        </td>
                        <td class="text-center">
                            <span class="order-badge">{{this.order}}</span>
                        </td>
                        <td class="text-center">
                            <div class="action-buttons">
                                <a href="/quiz/edit/{{this._id}}" class="action-btn action-edit" title="تعديل">
                                    <i class="fas fa-edit"></i>
                                    <span>تعديل</span>
                                </a>
                                <form action="/quiz/delete/{{this._id}}?_method=DELETE" method="post" class="d-inline">
                                    <button type="submit" class="action-btn action-delete" title="حذف" onclick="return confirm('هل أنت متأكد من حذف هذا السؤال؟')">
                                        <i class="fas fa-trash"></i>
                                        <span>حذف</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </table>
                    {{else}}
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="fas fa-inbox"></i>
                                <p>لا توجد أسئلة في هذا الدرس</p>
                                <a href="/quiz/create/{{lesson._id}}" class="modern-btn modern-btn-primary">أضف أول سؤال</a>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    * { direction: rtl; text-align: right; }
    
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #eef2ff;
        --success: #10b981;
        --success-light: #d1fae5;
        --warning: #f59e0b;
        --warning-light: #fef3c7;
        --danger: #ef4444;
        --danger-light: #fee2e2;
        --info: #3b82f6;
        --info-light: #dbeafe;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --radius-sm: 0.375rem;
        --radius-md: 0.5rem;
        --radius-lg: 0.75rem;
        --radius-xl: 1rem;
    }
    
    .modern-card {
        background: white;
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        margin: 1.5rem;
    }
    
    .modern-card-header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, var(--gray-50) 0%, white 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .header-actions {
        display: flex;
        gap: 0.75rem;
    }
    
    .modern-title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .modern-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-primary-light { background: var(--primary-light); }
    .text-primary { color: var(--primary); }
    
    .modern-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 0.25rem 0;
    }
    
    .modern-subtitle {
        font-size: 0.875rem;
        color: var(--gray-500);
        margin: 0;
    }
    
    .modern-card-body {
        padding: 2rem;
    }
    
    .lesson-info-cards {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    
    .info-card-mini {
        flex: 1;
        background: var(--gray-50);
        border-radius: var(--radius-lg);
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border: 1px solid var(--gray-200);
    }
    
    .info-icon-branch, .info-icon-subject, .info-icon-unit {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }
    
    .info-icon-branch { background: var(--info-light); color: var(--info); }
    .info-icon-subject { background: var(--success-light); color: var(--success); }
    .info-icon-unit { background: var(--warning-light); color: var(--warning); }
    
    .info-content {
        flex: 1;
    }
    
    .info-label-branch, .info-label-subject, .info-label-unit {
        font-size: 0.7rem;
        color: var(--gray-500);
        display: block;
    }
    
    .info-value-branch, .info-value-subject, .info-value-unit {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--gray-700);
    }
    
    .stats-row-mini {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    
    .stat-mini {
        flex: 1;
        text-align: center;
        padding: 0.75rem;
        background: white;
        border-radius: var(--radius-lg);
        border: 1px solid var(--gray-200);
    }
    
    .stat-mini-number {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
    }
    
    .stat-mini-label {
        font-size: 0.7rem;
        color: var(--gray-500);
    }
    
    .table-wrapper {
        overflow-x: auto;
        border-radius: var(--radius-lg);
        border: 1px solid var(--gray-200);
    }
    
    .modern-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }
    
    .modern-table thead {
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
    }
    
    .modern-table th {
        padding: 0.875rem 1rem;
        font-weight: 600;
        color: var(--gray-600);
        font-size: 0.7rem;
        text-transform: uppercase;
    }
    
    .modern-table td {
        padding: 0.875rem 1rem;
        border-bottom: 1px solid var(--gray-100);
        color: var(--gray-700);
        vertical-align: middle;
    }
    
    .modern-table tbody tr:hover {
        background: var(--gray-50);
    }
    
    .question-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .question-icon {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-md);
        background: var(--primary-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
    }
    
    .question-details {
        flex: 1;
    }
    
    .question-media-indicator {
        font-size: 0.7rem;
        color: var(--info);
        margin-top: 0.25rem;
    }
    
    .type-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.7rem;
        font-weight: 500;
    }
    
    .type-single {
        background: var(--warning-light);
        color: var(--warning);
    }
    
    .type-multi {
        background: var(--danger-light);
        color: var(--danger);
    }
    
    .points-badge {
        display: inline-block;
        background: var(--primary-light);
        color: var(--primary);
        padding: 0.25rem 0.5rem;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 0.75rem;
    }
    
    .order-badge {
        background: var(--gray-100);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--gray-600);
        display: inline-block;
    }
    
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }
    
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-md);
        font-size: 0.7rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        text-decoration: none;
    }
    
    .action-edit {
        background: var(--warning-light);
        color: var(--warning);
    }
    
    .action-edit:hover {
        background: var(--warning);
        color: white;
    }
    
    .action-delete {
        background: var(--danger-light);
        color: var(--danger);
    }
    
    .action-delete:hover {
        background: var(--danger);
        color: white;
    }
    
    .modern-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
    }
    
    .modern-btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
    }
    
    .modern-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .modern-btn-success {
        background: linear-gradient(135deg, var(--success) 0%, #059669 100%);
        color: white;
    }
    
    .modern-btn-success:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
        color: white;
    }
    
    .modern-btn-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
        border: 1px solid var(--gray-200);
    }
    
    .modern-btn-secondary:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem;
    }
    
    .empty-state i {
        font-size: 3rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
        display: inline-block;
    }
    
    .empty-state p {
        color: var(--gray-500);
        margin-bottom: 1rem;
    }
    
    .col-number { width: 50px; }
    .col-type { width: 110px; }
    .col-points { width: 70px; }
    .col-order { width: 70px; }
    .col-actions { width: 130px; }
    .text-center { text-align: center; }
    
    @media (max-width: 768px) {
        .modern-card {
            margin: 1rem;
        }
        .modern-card-header,
        .modern-card-body {
            padding: 1rem;
        }
        .lesson-info-cards {
            flex-direction: column;
        }
        .stats-row-mini {
            grid-template-columns: repeat(2, 1fr);
        }
        .action-btn span, .quiz-btn span {
            display: none;
        }
        .action-btn {
            padding: 0.4rem;
        }
    }
</style>