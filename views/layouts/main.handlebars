            </a>
        </div>
        {{#if (eq user.role 'super_admin')}}
<div class="nav-header">المشرفون</div>
<div class="nav-item">
    <a href="/admin-users" class="nav-link {{#if active.adminUsers}}active{{/if}}">
        <i class="fas fa-user-shield"></i>
