<!-- صلاحيات المستخدمين -->
{{#if (eq user.role 'super_admin')}}
<div class="nav-item">
    <a href="/permissions" class="nav-link {{#if active.permissions}}active{{/if}}">
        <i class="fas fa-lock"></i>
        <span>الصلاحيات</span>
    </a>
</div>
{{/if}}
{{/if}}

        
        <!-- الحساب -->
        <div class="nav-header">الحساب</div>
        <div class="nav-item">
            <a href="/logout" class="nav-link">
                <i class="fas fa-sign-out-alt"></i>
                <span>تسجيل الخروج</span>
            </a>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="main-content">
    <!-- Top Bar -->
    <div class="top-bar">
        <button class="menu-toggle" id="menuToggle">
            <i class="fas fa-bars"></i>
        </button>
        <div class="page-title">{{title}}</div>
        <div class="user-menu">
            <div class="notification">
                <i class="far fa-bell"></i>
                <span class="notification-badge">0</span>
            </div>
            <div class="dropdown">
                <i class="fas fa-user-circle" style="font-size: 1.3rem; cursor: pointer;"></i>
                <div class="dropdown-menu">
                    <a href="/profile" class="dropdown-item">ملفي الشخصي</a>
                    <div class="dropdown-divider"></div>
                    <a href="/logout" class="dropdown-item">تسجيل الخروج</a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Content Area -->
    <div class="content-area">
        {{#if success}}
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> {{success}}
            </div>
        {{/if}}
        
        {{#if error}}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> {{error}}
            </div>
        {{/if}}
        
        {{#if warning}}
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i> {{warning}}
            </div>
        {{/if}}
        
        {{#if info}}
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> {{info}}
            </div>
        {{/if}}
        
        {{{body}}}
    </div>
</div>

<script>
    // Toggle sidebar on mobile
    const menuToggle = document.getElementById('menuToggle');
    if (menuToggle) {
        menuToggle.addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('open');
        });
    }
    
    // Auto close alerts after 5 seconds
    setTimeout(function() {
        document.querySelectorAll('.alert').forEach(function(alert) {
            alert.style.opacity = '0';
            setTimeout(function() {
                if (alert && alert.remove) alert.remove();
            }, 500);
        });
    }, 5000);
    
    // Delete confirmation
    document.querySelectorAll('.delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const form = this.closest('form');
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: "هذا الإجراء لا يمكن التراجع عنه!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء'
            }).then((result) => {
                if (result.isConfirmed && form) {
                    form.submit();
                }
            });
        });
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // Initialize DataTables if present
    if ($.fn.DataTable) {
        $('.datatable').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json'
            },
            pageLength: 10,
            responsive: true
        });
    }
</script>
<script>
    // Récupérer le nombre de contenus en attente (pour super_admin)
    async function loadPendingCount() {
        const pendingCountElement = document.getElementById('pendingCount');
        if (pendingCountElement) {
            try {
                const response = await fetch('/approval/api/pending-count');
                const data = await response.json();
                if (data.count > 0) {
                    pendingCountElement.style.display = 'inline-block';
                    pendingCountElement.textContent = data.count;
                    pendingCountElement.classList.add('badge-pulse');
                } else {
                    pendingCountElement.style.display = 'none';
                }
            } catch (error) {
                console.error('Error loading pending count:', error);
            }
        }
    }
    
    // Charger le nombre de contenus en attente au chargement de la page
    document.addEventListener('DOMContentLoaded', function() {
        loadPendingCount();
        // Rafraîchir toutes les 30 secondes
        setInterval(loadPendingCount, 30000);
    });
</script>
<script>
    // Charger les notifications en temps réel
async function loadNotifications() {
    try {
        const response = await fetch('/notifications/api/list?limit=5');
        const data = await response.json();
        
        if (data.success) {
            // Mettre à jour le badge
            const badge = document.getElementById('notificationBadge');
            if (data.unreadCount > 0) {
                badge.style.display = 'inline-block';
                badge.textContent = data.unreadCount > 9 ? '9+' : data.unreadCount;
            } else {
                badge.style.display = 'none';
            }
            
            // Remplir la liste
            const container = document.getElementById('notificationList');
            if (data.notifications.length === 0) {
                container.innerHTML = '<div class="dropdown-item text-center text-muted">لا توجد إشعارات</div>';
            } else {
                container.innerHTML = data.notifications.map(n => `
                    <a href="${n.actionUrl || '#'}" class="dropdown-item ${!n.isRead ? 'bg-light' : ''}" onclick="markAsRead('${n._id}')">
                        <div class="media">
                            <div class="media-body">
                                <h6 class="dropdown-header-title">${n.title}</h6>
                                <p class="dropdown-item-text small">${n.message.substring(0, 60)}...</p>
                                <small class="text-muted">${new Date(n.createdAt).toLocaleDateString('ar')}</small>
                            </div>
                        </div>
                    </a>
                `).join('');
            }
        }
    } catch (error) {
        console.error('Erreur chargement notifications:', error);
    }
}

async function markAsRead(id) {
    try {
        await fetch(`/notifications/api/read/${id}`, { method: 'PUT' });
        loadNotifications();
    } catch (error) {
        console.error(error);
    }
}

document.getElementById('markAllReadDropdown')?.addEventListener('click', async () => {
    await fetch('/notifications/api/read-all', { method: 'PUT' });
    loadNotifications();
});

// Charger au chargement de la page
setInterval(loadNotifications, 30000); // Toutes les 30 secondes
loadNotifications();
</script>

</body>
</html>