        <!-- المستخدمون -->
        <div class="nav-header">المستخدمون</div>
        <div class="nav-item">
            <a href="/users" class="nav-link {{#if active.users}}active{{/if}}">
                <i class="fas fa-users"></i>
                <span>المستخدمون</span>
            </a>
