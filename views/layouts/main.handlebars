        <!-- التدقيق والأمان (للمديرين فقط) -->
{{#if (or (eq user.role 'admin') (eq user.role 'super_admin'))}}
<div class="nav-header">التدقيق والأمان</div>

<!-- سجل النشاطات -->
<div class="nav-item">
    <a href="/activity" class="nav-link {{#if active.activity}}active{{/if}}">
